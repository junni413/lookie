# ========================================================
# MySQL 컨테이너 초기 설정
# ========================================================
MYSQL_DATABASE=
MYSQL_ROOT_PASSWORD=
MYSQL_USER=
MYSQL_PASSWORD=

# ========================================================
# Backend가 사용할 DB 접속 정보 (host는 mysql 서비스명)
# ========================================================
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=

# ========================================================
# JWT settings
# ========================================================
JWT_SECRET=
JWT_EXPIRATION=

# ========================================================
# Refresh Token 14일 (14 * 24 * 60 * 60 * 1000)
# ========================================================
JWT_REFRESH_EXPIRATION=

# ========================================================
# CORS 허용 오리진 (개발용은 *, 배포 시 도메인 변경)
# ========================================================
CORS_ALLOWED_ORIGINS=

# ========================================================
# Gmail SMTP
# ========================================================
MAIL_USERNAME=
MAIL_PASSWORD=

# ========================================================
# Docker Hub 이미지 정보
# ========================================================
REGISTRY_IMAGE_BACKEND=
REGISTRY_IMAGE_NGINX=
