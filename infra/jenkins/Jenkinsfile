pipeline {
  agent any

  environment {
    DEPLOY_HOST    = 'i14b105.p.ssafy.io'
    DEPLOY_USER    = 'ubuntu'
    DEPLOY_DIR     = '/home/ubuntu/lookie/S14P11B105'
    TARGET_BRANCH  = 'feat/S14P11B105-28_CICD'

    NODE_VERSION   = '24'
    SSH_CRED_ID    = 'ec2-ssh-key'

    // ✅ GitLab 토큰(Username/Password) credentialsId
    GITLAB_CRED_ID = 'gitlab-deploy-token'

    // ✅ 원격에서 clone/fetch 할 Git URL (토큰은 런타임에 주입)
    GIT_REPO_HTTP  = 'lab.ssafy.com/s14-webmobile1-sub1/S14P11B105.git'
  }

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
        sh '''#!/usr/bin/env bash
          set -e
          echo "[Checkout] GIT_BRANCH=${GIT_BRANCH}"
          git rev-parse HEAD
        '''
      }
    }

    stage('Guard: Only Target Branch') {
      steps {
        script {
          def b = (env.gitlabBranch ?: env.GIT_BRANCH ?: "")
          b = b.replaceFirst(/^origin\\//, "")
               .replaceFirst(/^\\*\\//, "")

          echo "[Guard] detected branch = ${b}"

          if (b != env.TARGET_BRANCH) {
            currentBuild.result = 'NOT_BUILT'
            error("Skip: only runs for ${env.TARGET_BRANCH} (current: ${b})")
          }
        }
      }
    }

    stage('Build/Test') {
      steps {
        sh '''#!/usr/bin/env bash
          set -euo pipefail
          echo "=== [Build/Test] start ==="

          # --------------------------
          # Backend (Spring - Maven)
          # --------------------------
          if [ -f "app/backend/mvnw" ]; then
            echo "[Backend] mvnw test"
            pushd app/backend >/dev/null
            chmod +x mvnw
            ./mvnw -B test
            popd >/dev/null
          else
            echo "[Backend] skip (no app/backend/mvnw)"
          fi

          # --------------------------
          # Frontend (React/Vite)
          # - Jenkins sh는 /bin/sh일 수 있어 nvm 자동 로드가 안 됨
          # - bash -lc 로 로그인 셸로 실행해서 nvm 환경 로드
          # --------------------------
          if [ -f "app/frontend/package.json" ]; then
            echo "[Frontend] npm install & build (via bash -lc + nvm)"

            bash -lc "
              set -euo pipefail
              export NVM_DIR=\\\"\\$HOME/.nvm\\\"
              [ -s \\\"\\$NVM_DIR/nvm.sh\\\" ] && . \\\"\\$NVM_DIR/nvm.sh\\\"

              nvm use ${NODE_VERSION} >/dev/null
              echo \\\"[Frontend] node=\\$(node -v), npm=\\$(npm -v)\\\"

              cd app/frontend
              if [ -f package-lock.json ]; then
                npm ci
              else
                npm install
              fi

              if npm run | grep -q ' build'; then
                npm run build
              else
                echo '[Frontend] skip build (no build script)'
              fi
            "
          else
            echo "[Frontend] skip (no app/frontend/package.json)"
          fi

          echo "=== [Build/Test] done ==="
        '''
      }
    }

    stage('Deploy to EC2') {
      steps {
        // ✅ 1) EC2 SSH 접속 키
        sshagent(credentials: ["${SSH_CRED_ID}"]) {

          // ✅ 2) GitLab 토큰(Username/Password) 꺼내서 원격 git fetch에 사용
          withCredentials([usernamePassword(
            credentialsId: "${GITLAB_CRED_ID}",
            usernameVariable: 'GL_USER',
            passwordVariable: 'GL_TOKEN'
          )]) {

            sh '''#!/usr/bin/env bash
              set -euo pipefail

              REMOTE="${DEPLOY_USER}@${DEPLOY_HOST}"
              # 토큰 포함 URL (원격에서 origin set-url에 사용)
              REPO_URL="https://${GL_USER}:${GL_TOKEN}@${GIT_REPO_HTTP}"

              ssh -o StrictHostKeyChecking=no "$REMOTE" /bin/bash -s <<EOF
set -euo pipefail

echo "=== [Deploy] start ==="
echo "[0] DEPLOY_DIR=${DEPLOY_DIR}"
echo "[0] TARGET_BRANCH=${TARGET_BRANCH}"

mkdir -p "${DEPLOY_DIR}"
cd "${DEPLOY_DIR}"

# 1) .git 없으면 최초 clone
if [ ! -d ".git" ]; then
  echo "[1] repo not found -> git clone"
  git clone "${REPO_URL}" .
else
  echo "[1] repo exists -> update origin url (token) and fetch"
  git remote set-url origin "${REPO_URL}"
fi

# 2) 브랜치 동기화
echo "[2] git sync to ${TARGET_BRANCH}"
git fetch --all --prune
git checkout "${TARGET_BRANCH}" || git checkout -b "${TARGET_BRANCH}" "origin/${TARGET_BRANCH}"
git reset --hard "origin/${TARGET_BRANCH}"

# (선택) 보안상 토큰 URL을 남기기 싫으면 여기서 origin을 '토큰 없는 URL'로 되돌릴 수도 있음
# git remote set-url origin "https://${GIT_REPO_HTTP}"

# 3) .env 체크
echo "[3] .env check"
if [ ! -f .env ]; then
  if [ -f .env.example ]; then
    cp .env.example .env
    echo "WARN: .env missing -> copied from .env.example (fill real values if needed)"
  else
    echo "WARN: .env missing and no .env.example"
  fi
fi

# 4) docker compose 배포
echo "[4] docker compose up"
docker compose -f docker-compose.yml up -d --build

echo "[5] docker ps"
docker ps

echo "=== [Deploy] done ==="
EOF
            '''
          }
        }
      }
    }
  }

  post {
    success { echo '✅ SUCCESS' }
    failure { echo '❌ FAILURE - check console log' }
  }
}
