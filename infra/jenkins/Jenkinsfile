pipeline {
  agent any

  environment {
    // GitLab webhook로부터 브랜치가 들어오면 Jenkins가 자동으로 env에 넣어주는 경우가 많지만,
    // 안전하게 기본값도 둠
    DEPLOY_HOST = "i14b105.p.ssafy.io"
    DEPLOY_USER = "ubuntu"
    DEPLOY_DIR  = "/home/ubuntu/S14P11B105"   // EC2에 클론해둔 경로
  }

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
        sh 'git rev-parse --abbrev-ref HEAD'
      }
    }

    stage('Build/Test (optional)') {
      steps {
        // 여기서 백엔드 테스트/프론트 테스트를 하고 싶으면 추가
        // 예) sh 'cd app/backend && ./gradlew test'
        // 예) sh 'cd app/frontend && npm ci && npm test'
        echo "skip for now"
      }
    }

    stage('Deploy to EC2') {
      when {
        anyOf {
          branch 'develop'
          branch 'master'
          branch 'release'
          // feature는 보통 배포 안 하는데, 지금은 CICD 브랜치 테스트 중이라 열어둘 수도 있음
          expression { return env.BRANCH_NAME?.startsWith("feat/") }
        }
      }
      steps {
        sshagent(credentials: ['ec2-ssh']) {
          sh """
            ssh -o StrictHostKeyChecking=no ${DEPLOY_USER}@${DEPLOY_HOST} '
              set -e
              cd ${DEPLOY_DIR}

              echo "[1] git fetch/pull"
              git fetch --all
              git checkout ${BRANCH_NAME}
              git pull origin ${BRANCH_NAME}

              echo "[2] docker compose build/up"
              docker compose -f docker-compose.yml pull || true
              docker compose -f docker-compose.yml up -d --build

              echo "[3] docker ps"
              docker ps
            '
          """
        }
      }
    }
  }

  post {
    success { echo "✅ SUCCESS" }
    failure { echo "❌ FAILURE - check console log" }
  }
}
