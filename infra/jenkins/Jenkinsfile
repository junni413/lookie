pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
    skipDefaultCheckout(true)
  }

  environment {
    // ============================================================
    // [DEPLOY] 배포 대상(EC2) 정보
    // ============================================================
    DEPLOY_HOST  = 'i14b105.p.ssafy.io'
    DEPLOY_USER  = 'ubuntu'
    DEPLOY_DIR   = '/home/ubuntu/lookie/S14P11B105'
    SSH_CRED_ID  = 'ec2-ssh-key'
    GIT_REPO_SSH = 'git@lab.ssafy.com:s14-webmobile1-sub1/S14P11B105.git'

    // ============================================================
    // [NOTIFY] Mattermost Webhook
    // ============================================================
    MM_WEBHOOK_CRED_ID = 'mattermost-webhook'
    PUBLIC_JENKINS_URL = 'http://i14b105.p.ssafy.io:9000'

    // ============================================================
    // [CI - Redis]
    // ============================================================
    CI_REDIS_CONTAINER = 'ci-redis'
    CI_REDIS_IMAGE     = 'redis:7-alpine'

    // ============================================================
    // Build speed (Docker)
    // ============================================================
    DOCKER_BUILDKIT = '1'
    COMPOSE_DOCKER_CLI_BUILD = '1'
  }

  stages {

    stage('Detect Context') {
      steps {
        script {
          def pick = { List<String> keys ->
            for (k in keys) {
              def v = env."${k}"
              if (v != null && v.toString().trim()) return v.toString().trim()
            }
            return ''
          }

          env.EVENT_KIND = pick(['OBJECT_KIND','object_kind','objectKind','X_GITLAB_EVENT','gitlabEventType','event_type'])
          env.EVENT_KIND = (env.EVENT_KIND ?: '').trim()
          if (env.EVENT_KIND.toLowerCase().contains('merge')) env.EVENT_KIND = 'merge_request'
          if (env.EVENT_KIND.toLowerCase().contains('push'))  env.EVENT_KIND = 'push'

          def refRaw = pick(['REF','ref','GIT_REF','gitRef','refChanges_0_refId'])
          env.PUSH_BRANCH = (refRaw ?: '').replace('refs/heads/', '').trim()

          env.MR_SOURCE = pick(['MR_SOURCE','mr_source','SOURCE_BRANCH','source_branch','sourceBranch','gitlabSourceBranch']).trim()
          env.MR_TARGET = pick(['MR_TARGET','mr_target','TARGET_BRANCH','target_branch','targetBranch','gitlabTargetBranch']).trim()

          env.ACTOR = pick([
            'MR_USER_NAME','MR_USER_USERNAME',
            'PUSH_USER_NAME','PUSH_USER_USERNAME',
            'user_name','user_username',
            'GITLAB_USER_NAME','GITLAB_USER_USERNAME',
            'gitlabUserName','gitlabUserUsername'
          ]).trim()
          if (!env.ACTOR) env.ACTOR = 'unknown'

          env.RUN_BACKEND  = "false"
          env.RUN_FRONTEND = "false"
          env.RUN_DEPLOY   = "false"

          if (env.EVENT_KIND == 'merge_request') {
            if ((env.MR_SOURCE ?: '').startsWith('feat/be/')) {
              env.RUN_BACKEND = "true"
            } else if ((env.MR_SOURCE ?: '').startsWith('feat/fe/')) {
              env.RUN_FRONTEND = "true"
            } else {
              env.RUN_BACKEND  = "true"
              env.RUN_FRONTEND = "true"
            }
          }

          if (env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop') {
            env.RUN_DEPLOY = "true"
          }

          // ✅ 실제로 checkout할 브랜치 결정 (MR이면 source, push면 push branch)
          env.CHECKOUT_BRANCH = ''
          if (env.EVENT_KIND == 'merge_request' && env.MR_SOURCE) {
            env.CHECKOUT_BRANCH = env.MR_SOURCE
          } else if (env.EVENT_KIND == 'push' && env.PUSH_BRANCH) {
            env.CHECKOUT_BRANCH = env.PUSH_BRANCH
          }

          echo """
[kind=${env.EVENT_KIND}]
actor=${env.ACTOR}
pushBranch=${env.PUSH_BRANCH}
mrSource=${env.MR_SOURCE}
mrTarget=${env.MR_TARGET}

checkoutBranch=${env.CHECKOUT_BRANCH}
plan: BE=${env.RUN_BACKEND}, FE=${env.RUN_FRONTEND}, DEPLOY=${env.RUN_DEPLOY}
""".trim()
        }
      }
    }

    stage('Checkout') {
      when {
        expression { env.RUN_BACKEND == "true" || env.RUN_FRONTEND == "true" || env.RUN_DEPLOY == "true" }
      }
      steps {
        checkout scm
        sh '''
          bash -lc '
            set -euo pipefail

            if [ -n "${CHECKOUT_BRANCH:-}" ]; then
              echo "== Checkout requested branch: ${CHECKOUT_BRANCH} =="

              # 원격 브랜치가 fetch 범위에 없을 수도 있으니 방어적으로 1회 더 fetch
              git fetch origin "+refs/heads/${CHECKOUT_BRANCH}:refs/remotes/origin/${CHECKOUT_BRANCH}" || true

              git rev-parse --verify "origin/${CHECKOUT_BRANCH}" >/dev/null 2>&1 || {
                echo "[ERROR] origin/${CHECKOUT_BRANCH} 를 찾지 못했습니다."
                git branch -r || true
                exit 1
              }

              git checkout -B "${CHECKOUT_BRANCH}" "origin/${CHECKOUT_BRANCH}"
            fi

            echo "== Current branch =="
            git branch --show-current
            git log -1 --oneline
          '
        '''
      }
    }

    // ============================================================
    // ✅ A방식: Redis를 6379로 고정해서 띄우고(ci 프로파일 강제)
    // ============================================================
    stage('Backend Test (Redis + Maven)') {
      when {
        expression { env.EVENT_KIND == 'merge_request' && env.RUN_BACKEND == "true" }
      }
      steps {
        dir('app/backend') {
          sh '''
            bash -lc '
              set -euo pipefail

              docker version >/dev/null 2>&1 || { echo "[ERROR] Jenkins 노드에서 docker를 사용할 수 없습니다."; exit 1; }

              echo "[CI] Pre-pull redis image (best effort)"
              docker pull "${CI_REDIS_IMAGE}" >/dev/null 2>&1 || true

              # (1) Redis 컨테이너 실행 (기존 있으면 제거)
              docker rm -f "${CI_REDIS_CONTAINER}" >/dev/null 2>&1 || true

              # ✅ A방식: 호스트 포트 6379 고정
              # (호스트에 이미 6379 사용 중이면 여기서 실패하므로 그땐 B방식으로)
              docker run -d --name "${CI_REDIS_CONTAINER}" -p 6379:6379 "${CI_REDIS_IMAGE}" >/dev/null

              # (2) Redis 준비될 때까지 최대 30초 대기
              for i in $(seq 1 30); do
                if docker exec "${CI_REDIS_CONTAINER}" redis-cli ping 2>/dev/null | grep -q PONG; then
                  echo "[CI] Redis is ready on localhost:6379"
                  break
                fi
                sleep 1
                if [ "$i" -eq 30 ]; then
                  echo "[ERROR] Redis readiness timeout."
                  docker logs "${CI_REDIS_CONTAINER}" || true
                  exit 1
                fi
              done

              # (3) Maven 테스트
              chmod +x mvnw || true

              # ✅ 프로파일/redis host/port 강제 (설정 흔들림 방지)
              export SPRING_PROFILES_ACTIVE=ci
              export SPRING_DATA_REDIS_HOST=127.0.0.1
              export SPRING_DATA_REDIS_PORT=6379
              export SPRING_REDIS_HOST=127.0.0.1
              export SPRING_REDIS_PORT=6379

              echo "[CI] Maven test with ci profile + redis=127.0.0.1:6379"
              ./mvnw -q clean test \
                -Dspring.profiles.active=ci \
                -Dspring.data.redis.host=127.0.0.1 \
                -Dspring.data.redis.port=6379 \
                -Dspring.redis.host=127.0.0.1 \
                -Dspring.redis.port=6379
            '
          '''
        }
      }
      post {
        always {
          sh '''
            bash -lc '
              docker rm -f "${CI_REDIS_CONTAINER}" >/dev/null 2>&1 || true
            '
          '''
        }
      }
    }

    stage('Frontend Build (React)') {
      when {
        expression { env.EVENT_KIND == 'merge_request' && env.RUN_FRONTEND == "true" }
      }
      steps {
        dir('app/frontend') {
          sh '''
            bash -lc '
              set -euo pipefail
              docker version >/dev/null 2>&1 || { echo "[ERROR] Jenkins 노드에서 docker를 사용할 수 없습니다."; exit 1; }

              echo "[CI] Pre-pull node image (best effort)"
              docker pull node:20-alpine >/dev/null 2>&1 || true

              mkdir -p "${HOME}/.npm"

              docker run --rm \
                -v "$PWD":/app -w /app \
                -v "${HOME}/.npm":/root/.npm \
                node:20-alpine sh -lc "
                  set -euo pipefail
                  npm ci
                  npm run build
                "
            '
          '''
        }
      }
    }

    stage('Deploy (develop push only)') {
      when {
        expression { env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop' }
      }
      steps {
        sshagent(credentials: [env.SSH_CRED_ID]) {
          sh '''
            bash -lc '
              set -euo pipefail
              mkdir -p ~/.ssh
              ssh-keyscan -H "${DEPLOY_HOST}" >> ~/.ssh/known_hosts 2>/dev/null || true

              ssh "${DEPLOY_USER}@${DEPLOY_HOST}" "
                set -euo pipefail

                mkdir -p '${DEPLOY_DIR}'
                cd '${DEPLOY_DIR}'

                if [ ! -d .git ]; then
                  git clone '${GIT_REPO_SSH}' .
                fi

                git fetch origin

                git checkout -B develop origin/develop

                has_svc() { docker compose config --services | grep -qx \"\$1\"; }

                if has_svc mysql;   then docker compose pull mysql   || true; fi
                if has_svc redis;   then docker compose pull redis   || true; fi
                if has_svc migrate; then docker compose pull migrate || true; fi

                if has_svc backend; then docker compose build backend; fi
                if has_svc nginx;   then docker compose build nginx;   fi

                if has_svc mysql; then docker compose up -d mysql; fi
                if has_svc redis; then docker compose up -d redis; fi

                if has_svc migrate; then
                  docker compose run --rm migrate
                fi

                if has_svc backend; then docker compose up -d backend; fi
                if has_svc nginx;   then docker compose up -d nginx;   fi
              "
            '
          '''
        }
      }
    }
  }

  post {
    always {
      script {
        def ok = (currentBuild.currentResult == 'SUCCESS')
        def kind = env.EVENT_KIND ?: ''
        def branch = (kind == 'merge_request') ? (env.MR_SOURCE ?: '') : (env.PUSH_BRANCH ?: env.BRANCH_NAME ?: '')
        def title = ok ? ":white_check_mark: Jenkins 성공" : ":x: Jenkins 실패"

        def jobName = (env.JOB_NAME ?: '').trim()
        def buildNo = (env.BUILD_NUMBER ?: '').trim()
        def jobPath = jobName ? jobName.split('/').collect { "job/${it}" }.join('/') : ''
        def buildUrl = jobPath ? "${env.PUBLIC_JENKINS_URL}/${jobPath}/${buildNo}/" : env.PUBLIC_JENKINS_URL

        mmNotify(ok, [
          title   : title,
          mention : '@channel',
          kind    : kind,
          actor   : env.ACTOR ?: 'unknown',
          branch  : branch,
          target  : (env.MR_TARGET ?: ''),
          buildUrl: buildUrl,
          credId  : env.MM_WEBHOOK_CRED_ID
        ])
      }
    }
  }
}

def mmNotify(boolean success, Map info) {
  def icon  = success ? ":jenkins:" : ":warning:"
  def title = info.title ?: (success ? ":white_check_mark: Jenkins 성공" : ":x: Jenkins 실패")

  def lines = []
  if (info.mention)  lines << "${info.mention}"
  if (info.kind)     lines << "**이벤트:** `${info.kind}`"
  if (info.actor)    lines << "**실행자:** `${info.actor}`"
  if (info.branch)   lines << "**브랜치:** `${info.branch}`"
  if (info.target)   lines << "**타겟:** `${info.target}`"
  if (info.buildUrl) lines << "**Jenkins:** ${info.buildUrl}"

  def payload = groovy.json.JsonOutput.toJson([
    username  : "Jenkins",
    icon_emoji: icon,
    text      : title + "\\n" + lines.join("\\n")
  ])

  writeFile file: 'mm_payload.json', text: payload

  withCredentials([string(credentialsId: info.credId, variable: 'MM_WEBHOOK')]) {
    sh '''
      curl -sS -X POST -H 'Content-Type: application/json' \
        --data-binary @mm_payload.json \
        "$MM_WEBHOOK" >/dev/null
    '''
  }
}
