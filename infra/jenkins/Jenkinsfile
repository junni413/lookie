pipeline {
  agent any
  options { timestamps(); disableConcurrentBuilds() }

  environment {
    // =========================
    // Deploy
    // =========================
    DEPLOY_HOST  = 'i14b105.p.ssafy.io'
    DEPLOY_USER  = 'ubuntu'
    DEPLOY_DIR   = '/home/ubuntu/lookie/S14P11B105'
    SSH_CRED_ID  = 'ec2-ssh-key'
    GIT_REPO_SSH = 'git@lab.ssafy.com:s14-webmobile1-sub1/S14P11B105.git'

    // =========================
    // Mattermost
    // =========================
    MM_WEBHOOK_CRED_ID = 'mattermost-webhook'

    // =========================
    // Jenkins Public URL (fix 8080 -> 9000)
    // =========================
    PUBLIC_JENKINS_URL = 'http://i14b105.p.ssafy.io:9000'

    // =========================
    // Logs (no script approvals)
    // =========================
    BACKEND_LOG  = 'ci_backend.log'
    FRONTEND_LOG = 'ci_frontend.log'
    DEPLOY_LOG   = 'ci_deploy.log'

    // How many lines to include in MM summary
    TAIL_LINES   = '120'
  }

  stages {

    stage('Detect Context') {
      steps {
        script {
          // Generic Webhook Trigger 변수명 + fallback
          env.EVENT_KIND  = (env.OBJECT_KIND ?: env.object_kind ?: '').trim()
          env.PUSH_BRANCH = (env.REF ?: env.ref ?: '').replace('refs/heads/', '').trim()

          env.MR_SOURCE   = (env.MR_SOURCE ?: env.mr_source ?: '').trim()
          env.MR_TARGET   = (env.MR_TARGET ?: env.mr_target ?: '').trim()

          // 누가 트리거했는지 (MR / push 모두 fallback)
          env.ACTOR = (
            env.MR_USER_NAME ?: env.MR_USER_USERNAME ?:
            env.PUSH_USER_NAME ?: env.PUSH_USER_USERNAME ?:
            env.user_name ?: env.user_username ?:
            'unknown'
          ).trim()

          // 실행 계획
          env.RUN_BACKEND  = "false"
          env.RUN_FRONTEND = "false"
          env.RUN_DEPLOY   = "false"

          if (env.EVENT_KIND == 'merge_request') {
            if ((env.MR_SOURCE ?: '').startsWith('feat/be/')) {
              env.RUN_BACKEND = "true"
            } else if ((env.MR_SOURCE ?: '').startsWith('feat/fe/')) {
              env.RUN_FRONTEND = "true"
            } else {
              env.RUN_BACKEND = "true"
              env.RUN_FRONTEND = "true"
            }
          }

          if (env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop') {
            env.RUN_DEPLOY = "true"
          }

          echo """
[Webhook]
- kind       = ${env.EVENT_KIND}
- actor      = ${env.ACTOR}
- pushBranch = ${env.PUSH_BRANCH}
- mrSource   = ${env.MR_SOURCE}
- mrTarget   = ${env.MR_TARGET}

[Plan]
- backendTest   = ${env.RUN_BACKEND}
- frontendBuild = ${env.RUN_FRONTEND}
- deploy        = ${env.RUN_DEPLOY}
""".trim()
        }
      }
    }

    stage('Checkout') {
      steps {
        checkout scm
        script {
          // MR이면 source 브랜치로 체크아웃
          // checkout scm이 이미 fetch 해오므로, 추가 fetch는 하지 않음(HTTPS 인증 이슈 방지)
          if (env.EVENT_KIND == 'merge_request' && env.MR_SOURCE) {
            sh """
              bash -lc '
                set -euo pipefail
                echo "== Checkout MR source branch: ${env.MR_SOURCE} =="

                git rev-parse --verify origin/${env.MR_SOURCE}
                git checkout -B ${env.MR_SOURCE} origin/${env.MR_SOURCE}

                echo "== Current branch =="
                git branch --show-current
                git log -1 --oneline
              '
            """
          }
        }
      }
    }

    // =========================
    // CI: Backend Test
    // =========================
    stage('Backend Test (Maven)') {
      when { expression { env.EVENT_KIND == 'merge_request' && env.RUN_BACKEND == "true" } }
      steps {
        dir('app/backend') {
          sh """
            bash -lc '
              set -euo pipefail
              : > ../../${BACKEND_LOG}

              echo "===== [Backend] mvnw -v =====" | tee -a ../../${BACKEND_LOG}
              chmod +x mvnw || true
              ./mvnw -v 2>&1 | tee -a ../../${BACKEND_LOG}

              echo "===== [Backend] mvnw clean test =====" | tee -a ../../${BACKEND_LOG}
              ./mvnw clean test 2>&1 | tee -a ../../${BACKEND_LOG}
            '
          """
        }
      }
    }

    // =========================
    // CI: Frontend Build
    // =========================
    stage('Frontend Build (React)') {
      when { expression { env.EVENT_KIND == 'merge_request' && env.RUN_FRONTEND == "true" } }
      steps {
        dir('app/frontend') {
          sh """
            bash -lc '
              set -euo pipefail
              : > ../../${FRONTEND_LOG}

              echo "===== [Frontend] docker version =====" | tee -a ../../${FRONTEND_LOG}
              docker version 2>&1 | tee -a ../../${FRONTEND_LOG}

              echo "===== [Frontend] node build (container) =====" | tee -a ../../${FRONTEND_LOG}
              docker run --rm \
                -v "\$PWD":/app -w /app \
                node:20-alpine sh -lc "
                  set -e
                  node -v
                  npm -v
                  npm ci
                  npm run build
                " 2>&1 | tee -a ../../${FRONTEND_LOG}
            '
          """
        }
      }
    }

    // =========================
    // CD: Deploy (develop push only)
    // =========================
    stage('Deploy (develop push only)') {
      when { expression { env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop' } }
      steps {
        sh """
          bash -lc '
            set -euo pipefail
            : > ${DEPLOY_LOG}
          '
        """

        sshagent(credentials: [env.SSH_CRED_ID]) {
          sh """
            bash -lc '
              set -euo pipefail

              echo "===== [Deploy] remote deploy start =====" | tee -a ${DEPLOY_LOG}

              ssh -o StrictHostKeyChecking=no ${DEPLOY_USER}@${DEPLOY_HOST} "
                set -e
                mkdir -p ${DEPLOY_DIR}
                cd ${DEPLOY_DIR}

                if [ ! -d .git ]; then
                  git clone ${GIT_REPO_SSH} .
                fi

                git fetch --all
                git checkout develop
                git reset --hard origin/develop

                docker compose up -d --build
              " 2>&1 | tee -a ${DEPLOY_LOG}

              echo "===== [Deploy] remote deploy done =====" | tee -a ${DEPLOY_LOG}
            '
          """
        }
      }
    }
  }

  post {
    always {
      script {
        def isMR   = (env.EVENT_KIND == 'merge_request')
        def isPush = (env.EVENT_KIND == 'push')

        def branch = isMR ? (env.MR_SOURCE ?: '') : (env.PUSH_BRANCH ?: env.BRANCH_NAME ?: '')
        def actor  = env.ACTOR ?: 'unknown'

        def commitMsg = sh(script: "git log -1 --pretty=%s", returnStdout: true).trim()
        def commitSha = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()

        def ranBE     = (env.RUN_BACKEND == "true")
        def ranFE     = (env.RUN_FRONTEND == "true")
        def ranDeploy = (env.RUN_DEPLOY == "true")

        def ok = (currentBuild.currentResult == 'SUCCESS')

        def label = isMR ? "CI" : (isPush ? "배포" : "빌드")
        def title = ok ? ":white_check_mark: ${label} 성공" : ":x: ${label} 실패"

        // Jenkins link (9000 고정)
        def jobName = env.JOB_NAME ?: ''
        def buildNo = env.BUILD_NUMBER ?: ''
        def buildUrlFixed   = "${env.PUBLIC_JENKINS_URL}/job/${jobName}/${buildNo}/"
        def consoleTextUrl  = buildUrlFixed + "consoleText"

        // Failure summary (tail from stage logs)
        def detailsParts = []

        // ✅ 성공/실패 상관없이 "최근 콘솔 느낌"으로 로그 tail을 붙이고 싶다면 여기서 항상 생성
        // 다만 메시지 길이 제한 때문에, 성공일 때는 과도하게 붙이지 않는 걸 추천(필요하면 아래 ok 조건 제거)
        def wantTail = (!ok)  // 실패일 때만 tail 포함. 성공에도 포함하고 싶으면 true로 바꿔도 됨.

        if (wantTail) {
          def n = (env.TAIL_LINES ?: '120').trim()

          if (ranBE) {
            def beTail = sh(script: "tail -n ${n} ${BACKEND_LOG} 2>/dev/null || true", returnStdout: true).trim()
            if (beTail) detailsParts << "### Backend (last ${n} lines)\n${beTail}"
          }
          if (ranFE) {
            def feTail = sh(script: "tail -n ${n} ${FRONTEND_LOG} 2>/dev/null || true", returnStdout: true).trim()
            if (feTail) detailsParts << "### Frontend (last ${n} lines)\n${feTail}"
          }
          if (ranDeploy) {
            def dpTail = sh(script: "tail -n ${n} ${DEPLOY_LOG} 2>/dev/null || true", returnStdout: true).trim()
            if (dpTail) detailsParts << "### Deploy (last ${n} lines)\n${dpTail}"
          }
          if (detailsParts.isEmpty()) detailsParts << "로그 파일이 없습니다. (스테이지 진입 전 실패했을 수 있음)"
        }

        mmNotify(ok, [
          title     : title,
          mention   : '@channel',
          kind      : env.EVENT_KIND,
          actor     : actor,
          branch    : branch,
          target    : (env.MR_TARGET ?: ''),
          commit    : "${commitSha} - ${commitMsg}",
          buildUrl  : buildUrlFixed,
          consoleUrl: consoleTextUrl,                 // ✅ consoleText 링크 추가
          details   : detailsParts.join("\n\n"),
          credId    : env.MM_WEBHOOK_CRED_ID,
          ranBE     : ranBE,
          ranFE     : ranFE,
          ranDeploy : ranDeploy
        ])
      }
    }
  }
}

/**
 * Mattermost Notify (no script approvals)
 */
def mmNotify(boolean success, Map info) {
  def icon  = success ? ":jenkins:" : ":warning:"
  def title = info.title ?: (success ? ":white_check_mark: Jenkins 성공" : ":x: Jenkins 실패")

  def lines = []
  if (info.mention)   lines << "${info.mention}"
  if (info.kind)      lines << "**이벤트:** `${info.kind}`"
  if (info.actor)     lines << "**실행자:** `${info.actor}`"
  if (info.branch)    lines << "**브랜치:** `${info.branch}`"
  if (info.target)    lines << "**타겟:** `${info.target}`"
  if (info.commit)    lines << "**커밋:** ${info.commit}"
  if (info.buildUrl)  lines << "**Jenkins:** ${info.buildUrl}"
  if (info.consoleUrl) lines << "**ConsoleText:** ${info.consoleUrl}"   // ✅ 콘솔 링크

  def ran = []
  if (info.ranBE)     ran << "BE"
  if (info.ranFE)     ran << "FE"
  if (info.ranDeploy) ran << "DEPLOY"
  if (!ran.isEmpty()) lines << "**실행:** `${ran.join(' + ')}`"

  // 실패 요약(로그 tail) - 길이 제한 방지
  if (!success && info.details) {
    def max = 2800
    def clipped = info.details.size() > max ? (info.details.take(max) + "\n...(truncated)") : info.details
    lines << "**실패 요약:**\n```text\n${clipped}\n```"
  }

  def payload = groovy.json.JsonOutput.toJson([
    username  : "Jenkins",
    icon_emoji: icon,
    text      : title + "\n" + lines.join("\n")
  ])

  writeFile file: 'mm_payload.json', text: payload

  withCredentials([string(credentialsId: info.credId, variable: 'MM_WEBHOOK')]) {
    sh '''
      curl -sS -X POST -H 'Content-Type: application/json' \
        --data-binary @mm_payload.json \
        "$MM_WEBHOOK" || true
    '''
  }
}
