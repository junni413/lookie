pipeline {
  agent any

  options {
    timestamps()                   // 콘솔 로그에 시간 출력
    disableConcurrentBuilds()      // 같은 Job 동시 실행 방지
    skipDefaultCheckout(true)      // ✅ Declarative 자동 checkout 끄고, Checkout 스테이지만 사용
  }

  environment {
    // ============================================================
    // [DEPLOY] 배포 대상(EC2) 정보
    // ============================================================
    DEPLOY_HOST  = 'i14b105.p.ssafy.io'
    DEPLOY_USER  = 'ubuntu'
    DEPLOY_DIR   = '/home/ubuntu/lookie/S14P11B105'
    SSH_CRED_ID  = 'ec2-ssh-key'
    // ✅ 배포 서버에서만 사용하는 SSH clone URL (Jenkins checkout은 Job 설정의 HTTPS + token 사용)
    GIT_REPO_SSH = 'git@lab.ssafy.com:s14-webmobile1-sub1/S14P11B105.git'

    // ============================================================
    // [NOTIFY] Mattermost
    // ============================================================
    MM_WEBHOOK_CRED_ID = 'mattermost-webhook'
    PUBLIC_JENKINS_URL = 'http://i14b105.p.ssafy.io:9000'

    // ============================================================
    // [LOG] 로그 파일명
    // ============================================================
    BACKEND_LOG  = 'ci_backend.log'
    FRONTEND_LOG = 'ci_frontend.log'
    DEPLOY_LOG   = 'ci_deploy.log'

    // ============================================================
    // [CI - Redis] (랜덤 호스트 포트로 실행: -p 0:6379)
    // ============================================================
    CI_REDIS_CONTAINER = 'ci-redis'
    CI_REDIS_IMAGE     = 'redis:7-alpine'

    // ============================================================
    // [CI - MySQL] (랜덤 호스트 포트로 실행: -p 0:3306)
    // ============================================================
    CI_MYSQL_CONTAINER = 'ci-mysql'
    CI_MYSQL_IMAGE     = 'mysql:8.0'
    CI_MYSQL_DB        = 'lookie'
    CI_MYSQL_USER      = 'lookie'
    CI_MYSQL_PASSWORD  = 'lookiepass'
    CI_MYSQL_ROOTPW    = 'rootpass'

    // ============================================================
    // Docker build 성능
    // ============================================================
    DOCKER_BUILDKIT = '1'
    COMPOSE_DOCKER_CLI_BUILD = '1'
  }

  stages {

    // ============================================================
    // 1) Webhook payload 기반으로 이벤트 종류/브랜치/실행 범위 결정
    // ============================================================
    stage('Detect Context') {
      steps {
        script {
          def pick = { List<String> keys ->
            for (k in keys) {
              def v = env."${k}"
              if (v != null && v.toString().trim()) return v.toString().trim()
            }
            return ''
          }

          // 이벤트 종류 감지 (GitLab/Generic Webhook 변수 차이 흡수)
          env.EVENT_KIND = pick(['OBJECT_KIND','object_kind','objectKind','X_GITLAB_EVENT','gitlabEventType','event_type'])
          env.EVENT_KIND = (env.EVENT_KIND ?: '').trim()
          if (env.EVENT_KIND.toLowerCase().contains('merge')) env.EVENT_KIND = 'merge_request'
          if (env.EVENT_KIND.toLowerCase().contains('push'))  env.EVENT_KIND = 'push'

          // push 브랜치
          def refRaw = pick(['REF','ref','GIT_REF','gitRef','refChanges_0_refId'])
          env.PUSH_BRANCH = (refRaw ?: '').replace('refs/heads/', '').trim()

          // MR source/target
          env.MR_SOURCE = pick(['MR_SOURCE','mr_source','SOURCE_BRANCH','source_branch','sourceBranch','gitlabSourceBranch']).trim()
          env.MR_TARGET = pick(['MR_TARGET','mr_target','TARGET_BRANCH','target_branch','targetBranch','gitlabTargetBranch']).trim()

          // 실행자
          env.ACTOR = pick([
            'MR_USER_NAME','MR_USER_USERNAME',
            'PUSH_USER_NAME','PUSH_USER_USERNAME',
            'user_name','user_username',
            'GITLAB_USER_NAME','GITLAB_USER_USERNAME',
            'gitlabUserName','gitlabUserUsername'
          ]).trim()
          if (!env.ACTOR) env.ACTOR = 'unknown'

          // 실행 플래그 초기화
          env.RUN_BACKEND  = "false"
          env.RUN_FRONTEND = "false"
          env.RUN_DEPLOY   = "false"

          // ✅ MR이면 CI만 수행(배포 금지)
          if (env.EVENT_KIND == 'merge_request') {
            if ((env.MR_SOURCE ?: '').startsWith('feat/be/')) {
              env.RUN_BACKEND = "true"
            } else if ((env.MR_SOURCE ?: '').startsWith('feat/fe/')) {
              env.RUN_FRONTEND = "true"
            } else {
              env.RUN_BACKEND  = "true"
              env.RUN_FRONTEND = "true"
            }
          }

          // ✅ develop 브랜치 push면 배포만 수행(CI는 webhook 정책상 미실행)
          if (env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop') {
            env.RUN_DEPLOY = "true"
          }

          // checkout 브랜치 결정 (MR이면 source / push면 push branch)
          env.CHECKOUT_BRANCH = ''
          if (env.EVENT_KIND == 'merge_request' && env.MR_SOURCE) {
            env.CHECKOUT_BRANCH = env.MR_SOURCE
          } else if (env.EVENT_KIND == 'push' && env.PUSH_BRANCH) {
            env.CHECKOUT_BRANCH = env.PUSH_BRANCH
          }

          echo """
[kind=${env.EVENT_KIND}]
actor=${env.ACTOR}
pushBranch=${env.PUSH_BRANCH}
mrSource=${env.MR_SOURCE}
mrTarget=${env.MR_TARGET}

checkoutBranch=${env.CHECKOUT_BRANCH}
plan: BE=${env.RUN_BACKEND}, FE=${env.RUN_FRONTEND}, DEPLOY=${env.RUN_DEPLOY}
""".trim()
        }
      }
    }

    // ============================================================
    // 2) Checkout
    //  - checkout scm은 Jenkins가 credential을 주입해서 fetch/checkout 함
    //  - shell에서 git fetch를 다시 치면 "Username for https://..." 에러가 날 수 있어
    //    (shell은 Jenkins의 GIT_ASKPASS 주입을 보장 못함)
    //  - 따라서 여기서는 fetch하지 않고, 이미 받아온 refs/remotes/origin/* 로 브랜치만 맞춘다.
    // ============================================================
    stage('Checkout') {
      when {
        expression { env.RUN_BACKEND == "true" || env.RUN_FRONTEND == "true" || env.RUN_DEPLOY == "true" }
      }
      steps {
        checkout scm

        sh '''
          bash -lc '
            set -euo pipefail

            if [ -n "${CHECKOUT_BRANCH:-}" ]; then
              echo "== Checkout requested branch: ${CHECKOUT_BRANCH} =="

              git rev-parse --verify "refs/remotes/origin/${CHECKOUT_BRANCH}" >/dev/null 2>&1 || {
                echo "[ERROR] origin/${CHECKOUT_BRANCH} 를 찾지 못했습니다."
                git branch -r || true
                exit 1
              }

              # 로컬 브랜치를 원격 브랜치 커밋으로 강제 맞춤
              git checkout -B "${CHECKOUT_BRANCH}" "refs/remotes/origin/${CHECKOUT_BRANCH}"
            fi

            echo "== Current branch =="
            git branch --show-current
            git log -1 --oneline
          '
        '''
      }
    }

    // ============================================================
    // 3) Backend Test
    //  - ✅ MySQL/Redis 모두 컨테이너로 띄움
    //  - ✅ 포트 충돌 방지를 위해 둘 다 랜덤 호스트 포트(-p 0:...) 사용
    //  - ✅ 실제 할당된 호스트 포트를 읽어서 spring 설정을 "강제 주입"
    // ============================================================
    stage('Backend Test (MySQL + Redis + Maven)') {
      when {
        expression { env.EVENT_KIND == 'merge_request' && env.RUN_BACKEND == "true" }
      }
      steps {
        dir('app/backend') {
          sh '''
            bash -lc '
              set -euo pipefail
              : > ../../${BACKEND_LOG}

              # Docker 사용 가능 확인
              docker version >/dev/null 2>&1 || {
                echo "[ERROR] Jenkins 노드에서 docker를 사용할 수 없습니다." | tee -a ../../${BACKEND_LOG}
                exit 1
              }

              echo "===== [Backend] start CI mysql/redis =====" | tee -a ../../${BACKEND_LOG}

              # ---- 기존 컨테이너 제거(충돌 방지) ----
              docker rm -f "${CI_REDIS_CONTAINER}" >/dev/null 2>&1 || true
              docker rm -f "${CI_MYSQL_CONTAINER}" >/dev/null 2>&1 || true

              # --------------------------------------------------------
              # (1) MySQL 컨테이너 실행 (랜덤 호스트 포트: 0:3306)
              # --------------------------------------------------------
              docker pull "${CI_MYSQL_IMAGE}" >/dev/null 2>&1 || true
              docker run -d --name "${CI_MYSQL_CONTAINER}" \
                -e MYSQL_ROOT_PASSWORD="${CI_MYSQL_ROOTPW}" \
                -e MYSQL_DATABASE="${CI_MYSQL_DB}" \
                -e MYSQL_USER="${CI_MYSQL_USER}" \
                -e MYSQL_PASSWORD="${CI_MYSQL_PASSWORD}" \
                -p 0:3306 \
                "${CI_MYSQL_IMAGE}" 2>&1 | tee -a ../../${BACKEND_LOG}

              # 할당된 호스트 포트 조회
              MYSQL_HOST_PORT="$(docker port "${CI_MYSQL_CONTAINER}" 3306/tcp | sed -E "s/.*:([0-9]+)$/\\1/" | tail -n 1)"
              if [ -z "${MYSQL_HOST_PORT}" ]; then
                echo "[ERROR] MySQL 호스트 포트 조회 실패" | tee -a ../../${BACKEND_LOG}
                docker logs "${CI_MYSQL_CONTAINER}" | tail -n 200 | tee -a ../../${BACKEND_LOG} || true
                exit 1
              fi
              echo "[CI] MySQL mapped host port: ${MYSQL_HOST_PORT}" | tee -a ../../${BACKEND_LOG}

              # MySQL readiness (mysqladmin ping + 쿼리)
              echo "===== [Backend] wait mysql ready =====" | tee -a ../../${BACKEND_LOG}
              for i in $(seq 1 90); do
                if docker exec "${CI_MYSQL_CONTAINER}" mysqladmin ping -uroot -p"${CI_MYSQL_ROOTPW}" --silent >/dev/null 2>&1; then
                  if docker exec "${CI_MYSQL_CONTAINER}" mysql -uroot -p"${CI_MYSQL_ROOTPW}" -e "SELECT 1" >/dev/null 2>&1; then
                    echo "[CI] MySQL is ready on localhost:${MYSQL_HOST_PORT}" | tee -a ../../${BACKEND_LOG}
                    break
                  fi
                fi
                echo "Waiting MySQL... ($i/90)" | tee -a ../../${BACKEND_LOG}
                sleep 1
                if [ "$i" -eq 90 ]; then
                  echo "[ERROR] MySQL readiness timeout." | tee -a ../../${BACKEND_LOG}
                  docker logs "${CI_MYSQL_CONTAINER}" | tail -n 200 | tee -a ../../${BACKEND_LOG} || true
                  exit 1
                fi
              done

              # --------------------------------------------------------
              # (2) Redis 컨테이너 실행 (랜덤 호스트 포트: 0:6379)
              # --------------------------------------------------------
              docker pull "${CI_REDIS_IMAGE}" >/dev/null 2>&1 || true
              docker run -d --name "${CI_REDIS_CONTAINER}" \
                -p 0:6379 \
                "${CI_REDIS_IMAGE}" 2>&1 | tee -a ../../${BACKEND_LOG}

              # 할당된 호스트 포트 조회
              REDIS_HOST_PORT="$(docker port "${CI_REDIS_CONTAINER}" 6379/tcp | sed -E "s/.*:([0-9]+)$/\\1/" | tail -n 1)"
              if [ -z "${REDIS_HOST_PORT}" ]; then
                echo "[ERROR] Redis 호스트 포트 조회 실패" | tee -a ../../${BACKEND_LOG}
                docker logs "${CI_REDIS_CONTAINER}" | tail -n 200 | tee -a ../../${BACKEND_LOG} || true
                exit 1
              fi
              echo "[CI] Redis mapped host port: ${REDIS_HOST_PORT}" | tee -a ../../${BACKEND_LOG}

              # Redis readiness
              echo "===== [Backend] wait redis ready =====" | tee -a ../../${BACKEND_LOG}
              for i in $(seq 1 30); do
                if docker exec "${CI_REDIS_CONTAINER}" redis-cli ping 2>/dev/null | grep -q PONG; then
                  echo "[CI] Redis is ready on localhost:${REDIS_HOST_PORT}" | tee -a ../../${BACKEND_LOG}
                  break
                fi
                echo "Waiting Redis... ($i/30)" | tee -a ../../${BACKEND_LOG}
                sleep 1
                if [ "$i" -eq 30 ]; then
                  echo "[ERROR] Redis readiness timeout." | tee -a ../../${BACKEND_LOG}
                  docker logs "${CI_REDIS_CONTAINER}" | tail -n 200 | tee -a ../../${BACKEND_LOG} || true
                  exit 1
                fi
              done

              # --------------------------------------------------------
              # (3) Maven test 실행
              #  - ✅ 핵심: datasource/redis host/port를 "이번 컨테이너"로 강제 주입
              # --------------------------------------------------------
              chmod +x mvnw || true
              echo "===== [Backend] mvnw clean test (profile=ci) =====" | tee -a ../../${BACKEND_LOG}

              ./mvnw -q clean test \
                -Dspring.profiles.active=ci \
                -Dspring.datasource.url="jdbc:mysql://127.0.0.1:${MYSQL_HOST_PORT}/${CI_MYSQL_DB}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC" \
                -Dspring.datasource.username="${CI_MYSQL_USER}" \
                -Dspring.datasource.password="${CI_MYSQL_PASSWORD}" \
                -Dspring.data.redis.host=127.0.0.1 \
                -Dspring.data.redis.port="${REDIS_HOST_PORT}" \
                -Dspring.redis.host=127.0.0.1 \
                -Dspring.redis.port="${REDIS_HOST_PORT}" \
                2>&1 | tee -a ../../${BACKEND_LOG}
            '
          '''
        }
      }
      post {
        always {
          // 성공/실패와 무관하게 CI 컨테이너 정리
          sh '''
            bash -lc '
              docker rm -f "${CI_REDIS_CONTAINER}" >/dev/null 2>&1 || true
              docker rm -f "${CI_MYSQL_CONTAINER}" >/dev/null 2>&1 || true
            '
          '''
        }
      }
    }

    // ============================================================
    // 4) Frontend Build (MR에서만)
    // ============================================================
    stage('Frontend Build (React)') {
      when {
        expression { env.EVENT_KIND == 'merge_request' && env.RUN_FRONTEND == "true" }
      }
      steps {
        dir('app/frontend') {
          sh '''
            bash -lc '
              set -euo pipefail
              : > ../../${FRONTEND_LOG}

              docker version >/dev/null 2>&1 || {
                echo "[ERROR] Jenkins 노드에서 docker를 사용할 수 없습니다." | tee -a ../../${FRONTEND_LOG}
                exit 1
              }

              docker pull node:20-alpine >/dev/null 2>&1 || true
              mkdir -p "${HOME}/.npm"

              docker run --rm \
                -v "$PWD":/app -w /app \
                -v "${HOME}/.npm":/root/.npm \
                node:20-alpine sh -lc "
                  set -euo pipefail
                  npm ci
                  npm run build
                " 2>&1 | tee -a ../../${FRONTEND_LOG}
            '
          '''
        }
      }
    }

    // ============================================================
    // 5) Deploy (push develop에서만)
    // ============================================================
    stage('Deploy (develop push only)') {
      when {
        expression { env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop' }
      }
      steps {
        sshagent(credentials: [env.SSH_CRED_ID]) {
          sh '''
            bash -lc '
              set -euo pipefail
              : > ${DEPLOY_LOG}

              mkdir -p ~/.ssh
              ssh-keyscan -H "${DEPLOY_HOST}" >> ~/.ssh/known_hosts 2>/dev/null || true

              ssh "${DEPLOY_USER}@${DEPLOY_HOST}" "
                set -euo pipefail

                mkdir -p '${DEPLOY_DIR}'
                cd '${DEPLOY_DIR}'

                # 최초 배포면 clone
                if [ ! -d .git ]; then
                  git clone '${GIT_REPO_SSH}' .
                fi

                # develop 강제 동기화
                git fetch origin
                git checkout -B develop origin/develop

                # compose 서비스 존재 여부 체크
                has_svc() { docker compose config --services | grep -qx \"\$1\"; }

                # 이미지 기반 서비스는 pull(베이스 이미지/마이그레이션 pull 시간 절약)
                if has_svc mysql;   then docker compose pull mysql   || true; fi
                if has_svc redis;   then docker compose pull redis   || true; fi
                if has_svc migrate; then docker compose pull migrate || true; fi

                # build 정의 있는 것만 build
                if has_svc backend; then docker compose build backend; fi
                if has_svc nginx;   then docker compose build nginx;   fi

                # 의존 서비스 먼저 기동
                if has_svc mysql; then docker compose up -d mysql; fi
                if has_svc redis; then docker compose up -d redis; fi

                # 마이그레이션(실패 시 배포 중단)
                if has_svc migrate; then docker compose run --rm migrate; fi

                # 앱 기동
                if has_svc backend; then docker compose up -d backend; fi
                if has_svc nginx;   then docker compose up -d nginx;   fi
              " 2>&1 | tee -a ${DEPLOY_LOG}
            '
          '''
        }
      }
    }
  }

  // ============================================================
  // post: 항상 Mattermost 알림 전송
  // ============================================================
  post {
    always {
      script {
        def ok = (currentBuild.currentResult == 'SUCCESS')
        def kind = env.EVENT_KIND ?: ''
        def branch = (kind == 'merge_request') ? (env.MR_SOURCE ?: '') : (env.PUSH_BRANCH ?: env.BRANCH_NAME ?: '')
        def title = ok ? ":white_check_mark: Jenkins 성공" : ":x: Jenkins 실패"

        // Jenkins URL 구성 (폴더형 Job 대응)
        def jobName = (env.JOB_NAME ?: '').trim()
        def buildNo = (env.BUILD_NUMBER ?: '').trim()
        def jobPath = jobName ? jobName.split('/').collect { "job/${it}" }.join('/') : ''
        def buildUrl = jobPath ? "${env.PUBLIC_JENKINS_URL}/${jobPath}/${buildNo}/" : env.PUBLIC_JENKINS_URL

        mmNotify(ok, [
          title   : title,
          mention : '@channel',
          kind    : kind,
          actor   : env.ACTOR ?: 'unknown',
          branch  : branch,
          target  : (env.MR_TARGET ?: ''),
          buildUrl: buildUrl,
          credId  : env.MM_WEBHOOK_CRED_ID
        ])
      }
    }
  }
}

// ============================================================
// Mattermost 알림 함수
// ============================================================
def mmNotify(boolean success, Map info) {
  def icon  = success ? ":jenkins:" : ":warning:"
  def title = info.title ?: (success ? ":white_check_mark: Jenkins 성공" : ":x: Jenkins 실패")

  def lines = []
  if (info.mention)  lines << "${info.mention}"
  if (info.kind)     lines << "**이벤트:** `${info.kind}`"
  if (info.actor)    lines << "**실행자:** `${info.actor}`"
  if (info.branch)   lines << "**브랜치:** `${info.branch}`"
  if (info.target)   lines << "**타겟:** `${info.target}`"
  if (info.buildUrl) lines << "**Jenkins:** ${info.buildUrl}"

  def payload = groovy.json.JsonOutput.toJson([
    username  : "Jenkins",
    icon_emoji: icon,
    text      : title + "\n" + lines.join("\n")
  ])

  writeFile file: 'mm_payload.json', text: payload

  withCredentials([string(credentialsId: info.credId, variable: 'MM_WEBHOOK')]) {
    sh '''
      curl -sS -X POST -H 'Content-Type: application/json' \
        --data-binary @mm_payload.json \
        "$MM_WEBHOOK" >/dev/null
    '''
  }
}
