pipeline {
  agent any

  options {
    timestamps()                 // ✅ 콘솔 로그에 시간 표시
    disableConcurrentBuilds()    // ✅ 같은 Job이 동시에 여러 번 돌지 않게 잠금
  }

  environment {
    // =====================================================================
    // [DEPLOY] 배포 대상(EC2) 정보
    // =====================================================================
    DEPLOY_HOST  = 'i14b105.p.ssafy.io'
    DEPLOY_USER  = 'ubuntu'
    DEPLOY_DIR   = '/home/ubuntu/lookie/S14P11B105'
    SSH_CRED_ID  = 'ec2-ssh-key'  // Jenkins Credentials: SSH Private Key
    GIT_REPO_SSH = 'git@lab.ssafy.com:s14-webmobile1-sub1/S14P11B105.git'

    // =====================================================================
    // [NOTIFY] Mattermost 알림 Webhook (Jenkins Credentials: Secret text)
    // =====================================================================
    MM_WEBHOOK_CRED_ID = 'mattermost-webhook'

    // =====================================================================
    // [LINK] 외부에서 접근 가능한 Jenkins URL (Mattermost 메시지 링크용)
    // =====================================================================
    PUBLIC_JENKINS_URL = 'http://i14b105.p.ssafy.io:9000'

    // =====================================================================
    // [LOG] 단계별 로그 파일명 (원하면 artifact/archive로 남길 수 있음)
    // =====================================================================
    BACKEND_LOG  = 'ci_backend.log'
    FRONTEND_LOG = 'ci_frontend.log'
    DEPLOY_LOG   = 'ci_deploy.log'
  }

  stages {

    // =====================================================================
    // 1) Detect Context
    // - Generic Webhook Trigger로 들어온 변수들을 표준화
    // - 어떤 이벤트인지(MR/push), 어떤 브랜치인지 확인해서 실행 계획 수립
    // =====================================================================
    stage('Detect Context') {
      steps {
        script {
          // Generic Webhook Trigger에서 넘어오는 변수명이 케이스/플러그인마다 달라질 수 있어
          // 가능한 변수명을 모두 fallback으로 처리
          env.EVENT_KIND  = (env.OBJECT_KIND ?: env.object_kind ?: '').trim()  // merge_request / push ...
          env.PUSH_BRANCH = (env.REF ?: env.ref ?: '').replace('refs/heads/', '').trim()

          env.MR_SOURCE   = (env.MR_SOURCE ?: env.mr_source ?: '').trim()
          env.MR_TARGET   = (env.MR_TARGET ?: env.mr_target ?: '').trim()

          // 트리거 실행자 (MR/push 케이스 모두 대응)
          env.ACTOR = (
            env.MR_USER_NAME ?: env.MR_USER_USERNAME ?:
            env.PUSH_USER_NAME ?: env.PUSH_USER_USERNAME ?:
            env.user_name ?: env.user_username ?:
            'unknown'
          ).trim()

          // 기본 실행 계획은 모두 false로 시작
          env.RUN_BACKEND  = "false"
          env.RUN_FRONTEND = "false"
          env.RUN_DEPLOY   = "false"

          // ✅ MR 이벤트일 때: 브랜치 prefix로 어느 파트 실행할지 결정
          // - feat/be/* : 백엔드 테스트만
          // - feat/fe/* : 프론트 빌드만
          // - 그 외    : 둘 다
          if (env.EVENT_KIND == 'merge_request') {
            if ((env.MR_SOURCE ?: '').startsWith('feat/be/')) {
              env.RUN_BACKEND = "true"
            } else if ((env.MR_SOURCE ?: '').startsWith('feat/fe/')) {
              env.RUN_FRONTEND = "true"
            } else {
              env.RUN_BACKEND = "true"
              env.RUN_FRONTEND = "true"
            }
          }

          // ✅ push 이벤트에서 develop 브랜치면 배포 수행
          if (env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop') {
            env.RUN_DEPLOY = "true"
          }

          // 콘솔에 실행 계획 출력 (디버깅/가독성 ↑)
          echo """
[Webhook]
- kind       = ${env.EVENT_KIND}
- actor      = ${env.ACTOR}
- pushBranch = ${env.PUSH_BRANCH}
- mrSource   = ${env.MR_SOURCE}
- mrTarget   = ${env.MR_TARGET}

[Plan]
- backendTest   = ${env.RUN_BACKEND}
- frontendBuild = ${env.RUN_FRONTEND}
- deploy        = ${env.RUN_DEPLOY}
""".trim()
        }
      }
    }

    // =====================================================================
    // 2) Checkout
    // - Jenkins 기본 checkout(scm) 수행
    // - MR이면 "source 브랜치"를 명시적으로 체크아웃해서 빌드 대상 통일
    // =====================================================================
    stage('Checkout') {
      steps {
        checkout scm

        script {
          // MR 이벤트일 때 source branch를 origin 기준으로 체크아웃
          // (checkout scm이 이미 fetch를 하므로 추가 fetch는 생략)
          if (env.EVENT_KIND == 'merge_request' && env.MR_SOURCE) {
            sh """
              bash -lc '
                set -euo pipefail
                echo "== Checkout MR source branch: ${env.MR_SOURCE} =="

                git rev-parse --verify origin/${env.MR_SOURCE}
                git checkout -B ${env.MR_SOURCE} origin/${env.MR_SOURCE}

                echo "== Current branch =="
                git branch --show-current
                git log -1 --oneline
              '
            """
          }
        }
      }
    }

    // =====================================================================
    // 3) Backend Test (Maven)
    // - MR 이벤트 + RUN_BACKEND=true 일 때만 실행
    // - 환경 스냅샷(메모리/디스크) + 수행 시간(duration) 로그에 남김
    // =====================================================================
    stage('Backend Test (Maven)') {
      when { expression { env.EVENT_KIND == 'merge_request' && env.RUN_BACKEND == "true" } }

      steps {
        dir('app/backend') {
          sh """
            bash -lc '
              set -euo pipefail

              # 로그 파일 초기화
              : > ../../${BACKEND_LOG}

              START_TS=\$(date +%s)

              echo "===== [Backend] env snapshot =====" | tee -a ../../${BACKEND_LOG}
              free -m | tee -a ../../${BACKEND_LOG}
              df -h | tee -a ../../${BACKEND_LOG}

              echo "===== [Backend] mvnw -v =====" | tee -a ../../${BACKEND_LOG}
              chmod +x mvnw || true
              ./mvnw -v 2>&1 | tee -a ../../${BACKEND_LOG}

              echo "===== [Backend] mvnw clean test =====" | tee -a ../../${BACKEND_LOG}
              ./mvnw clean test 2>&1 | tee -a ../../${BACKEND_LOG}

              END_TS=\$(date +%s)
              echo "===== [Backend] duration: \$((END_TS-START_TS))s =====" | tee -a ../../${BACKEND_LOG}
            '
          """
        }
      }
    }

    // =====================================================================
    // 4) Frontend Build (React)
    // - MR 이벤트 + RUN_FRONTEND=true 일 때만 실행
    // - node를 Jenkins에 직접 설치하지 않고 docker run(node:20-alpine)으로 빌드
    // - 환경 스냅샷/디스크/도커 사용량/수행 시간 로그 남김
    // =====================================================================
    stage('Frontend Build (React)') {
      when { expression { env.EVENT_KIND == 'merge_request' && env.RUN_FRONTEND == "true" } }

      steps {
        dir('app/frontend') {
          sh """
            bash -lc '
              set -euo pipefail

              # 로그 파일 초기화
              : > ../../${FRONTEND_LOG}

              START_TS=\$(date +%s)

              echo "===== [Frontend] env snapshot =====" | tee -a ../../${FRONTEND_LOG}
              free -m | tee -a ../../${FRONTEND_LOG}
              df -h | tee -a ../../${FRONTEND_LOG}
              docker system df | tee -a ../../${FRONTEND_LOG}

              echo "===== [Frontend] docker version =====" | tee -a ../../${FRONTEND_LOG}
              docker version 2>&1 | tee -a ../../${FRONTEND_LOG}

              echo "===== [Frontend] node build (container) =====" | tee -a ../../${FRONTEND_LOG}
              docker run --rm \
                -v "\$PWD":/app -w /app \
                node:20-alpine sh -lc "
                  set -e
                  node -v
                  npm -v
                  npm ci
                  npm run build
                " 2>&1 | tee -a ../../${FRONTEND_LOG}

              END_TS=\$(date +%s)
              echo "===== [Frontend] duration: \$((END_TS-START_TS))s =====" | tee -a ../../${FRONTEND_LOG}
            '
          """
        }
      }
    }

    // =====================================================================
    // 5) Deploy (develop push only)
    // - push 이벤트 + develop 브랜치일 때만 실행
    // - StrictHostKeyChecking=no 대신 known_hosts에 host key 사전 등록
    // - docker compose build / up -d 분리하여 캐시 활용
    // =====================================================================
    stage('Deploy (develop push only)') {
      when { expression { env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop' } }

      steps {
        // 로컬(젠킨스 워커)에도 배포 로그 파일 남김
        sh """
          bash -lc '
            set -euo pipefail
            : > ${DEPLOY_LOG}
          '
        """

        // Jenkins Credentials의 SSH 키를 ssh-agent에 로드
        sshagent(credentials: [env.SSH_CRED_ID]) {
          sh """
            bash -lc '
              set -euo pipefail

              START_TS=\$(date +%s)

              # -------------------------------------------------------------
              # [보안] known_hosts 준비
              # - StrictHostKeyChecking=no를 쓰면 MITM 위험이 커짐
              # - ssh-keyscan으로 대상 호스트 키를 known_hosts에 기록
              #   (주의: ssh-keyscan도 네트워크가 오염되면 위험할 수 있으니
              #    가장 안전한 방법은 "정상 키를 직접 등록"하는 것)
              # -------------------------------------------------------------
              echo "===== [Deploy] prepare known_hosts =====" | tee -a ${DEPLOY_LOG}
              mkdir -p ~/.ssh
              touch ~/.ssh/known_hosts
              chmod 700 ~/.ssh
              chmod 600 ~/.ssh/known_hosts

              ssh-keyscan -H ${DEPLOY_HOST} >> ~/.ssh/known_hosts 2>/dev/null || true

              echo "===== [Deploy] remote deploy start =====" | tee -a ${DEPLOY_LOG}

              # -------------------------------------------------------------
              # [원격 배포]
              # - develop 최신화 후 compose build + up
              # -------------------------------------------------------------
              ssh ${DEPLOY_USER}@${DEPLOY_HOST} "
                set -e
                mkdir -p ${DEPLOY_DIR}
                cd ${DEPLOY_DIR}

                # 최초 1회 clone
                if [ ! -d .git ]; then
                  git clone ${GIT_REPO_SSH} .
                fi

                git fetch --all
                git checkout develop
                git reset --hard origin/develop

                # 캐시 활용을 위해 build/up 분리
                docker compose build
                docker compose up -d
              " 2>&1 | tee -a ${DEPLOY_LOG}

              echo "===== [Deploy] remote deploy done =====" | tee -a ${DEPLOY_LOG}
              END_TS=\$(date +%s)
              echo "===== [Deploy] duration: \$((END_TS-START_TS))s =====" | tee -a ${DEPLOY_LOG}
            '
          """
        }
      }
    }
  }

  // =====================================================================
  // post: always
  // - 파이프라인 결과와 메타정보를 정리해서 Mattermost로 알림
  // =====================================================================
  post {
    always {
      script {
        def isMR   = (env.EVENT_KIND == 'merge_request')
        def isPush = (env.EVENT_KIND == 'push')

        def branch = isMR ? (env.MR_SOURCE ?: '') : (env.PUSH_BRANCH ?: env.BRANCH_NAME ?: '')
        def actor  = env.ACTOR ?: 'unknown'

        // checkout 이후 workspace 기준 최신 커밋 정보
        def commitMsg = sh(script: "git log -1 --pretty=%s", returnStdout: true).trim()
        def commitSha = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()

        def ranBE     = (env.RUN_BACKEND == "true")
        def ranFE     = (env.RUN_FRONTEND == "true")
        def ranDeploy = (env.RUN_DEPLOY == "true")

        def ok = (currentBuild.currentResult == 'SUCCESS')

        def label = isMR ? "CI" : (isPush ? "배포" : "빌드")
        def title = ok ? ":white_check_mark: ${label} 성공" : ":x: ${label} 실패"

        // 외부에서 접근 가능한 Jenkins 링크 생성
        def jobName = env.JOB_NAME ?: ''
        def buildNo = env.BUILD_NUMBER ?: ''
        def buildUrlFixed = "${env.PUBLIC_JENKINS_URL}/job/${jobName}/${buildNo}/"

        mmNotify(ok, [
          title    : title,
          mention  : '@channel',
          kind     : env.EVENT_KIND,
          actor    : actor,
          branch   : branch,
          target   : (env.MR_TARGET ?: ''),
          commit   : "${commitSha} - ${commitMsg}",
          buildUrl : buildUrlFixed,
          credId   : env.MM_WEBHOOK_CRED_ID,
          ranBE    : ranBE,
          ranFE    : ranFE,
          ranDeploy: ranDeploy
        ])
      }
    }
  }
}

/**
 * Mattermost Notify (no script approvals)
 *
 * ✅ 정책:
 * - 실패 요약/consoleText 링크는 제거
 * - 알림 실패가 "조용히" 넘어가면 문제를 놓치기 쉬우므로,
 *   빌드는 실패로 만들지 않되 currentBuild.result를 UNSTABLE로 바꿈
 *   (파이프라인 자체는 통과하지만, 경고 상태로 남김)
 */
def mmNotify(boolean success, Map info) {
  def icon  = success ? ":jenkins:" : ":warning:"
  def title = info.title ?: (success ? ":white_check_mark: Jenkins 성공" : ":x: Jenkins 실패")

  // Mattermost 메시지 본문 구성
  def lines = []
  if (info.mention)  lines << "${info.mention}"
  if (info.kind)     lines << "**이벤트:** `${info.kind}`"
  if (info.actor)    lines << "**실행자:** `${info.actor}`"
  if (info.branch)   lines << "**브랜치:** `${info.branch}`"
  if (info.target)   lines << "**타겟:** `${info.target}`"
  if (info.commit)   lines << "**커밋:** ${info.commit}"
  if (info.buildUrl) lines << "**Jenkins:** ${info.buildUrl}"

  // 어떤 단계가 실행됐는지 표시
  def ran = []
  if (info.ranBE)     ran << "BE"
  if (info.ranFE)     ran << "FE"
  if (info.ranDeploy) ran << "DEPLOY"
  if (!ran.isEmpty()) lines << "**실행:** `${ran.join(' + ')}`"

  def payload = groovy.json.JsonOutput.toJson([
    username  : "Jenkins",
    icon_emoji: icon,
    text      : title + "\n" + lines.join("\n")
  ])

  // payload를 파일로 저장(디버깅/확인 편함)
  writeFile file: 'mm_payload.json', text: payload

  // Webhook은 Jenkins Credentials에서 가져옴(Secret Text)
  withCredentials([string(credentialsId: info.credId, variable: 'MM_WEBHOOK')]) {

    // ✅ 중요: 알림 실패를 "조용히 무시(|| true)" 하지 않고 상태를 확인
    // - returnStatus로 exit code만 받아서 파이프라인은 계속 진행
    // - 실패 시 currentBuild.result를 UNSTABLE로 마킹
    def rc = sh(
      script: '''
        curl -sS -X POST -H 'Content-Type: application/json' \
          --data-binary @mm_payload.json \
          "$MM_WEBHOOK"
      ''',
      returnStatus: true
    )

    if (rc != 0) {
      echo "⚠️ Mattermost notify failed (exit code: ${rc}). Marking build as UNSTABLE."
      currentBuild.result = 'UNSTABLE'
    } else {
      echo "✅ Mattermost notify sent."
    }
  }
}
