pipeline {
  agent any

  options {
    timestamps()                 // 콘솔 로그에 시간 출력
    disableConcurrentBuilds()    // 동일 Job 동시 실행 방지(배포 충돌 방지)
    skipDefaultCheckout(true)    // 기본 checkout 비활성화 → Checkout stage에서만 수행
  }

  environment {
    // ============================================================
    // [DEPLOY] EC2 배포 대상 정보
    // ============================================================
    DEPLOY_HOST  = 'i14b105.p.ssafy.io'
    DEPLOY_USER  = 'ubuntu'
    DEPLOY_DIR   = '/home/ubuntu/lookie/S14P11B105'
    SSH_CRED_ID  = 'ec2-ssh-key'
    GIT_REPO_SSH = 'git@lab.ssafy.com:s14-webmobile1-sub1/S14P11B105.git'
    COMPOSE_PROD_FILE = 'docker-compose.prod.yml'

    // ============================================================
    // [REGISTRY] DockerHub 이미지 정보
    // ============================================================
    DOCKERHUB_CRED_ID      = 'dockerhub-cred'
    REGISTRY_IMAGE_BACKEND = 'sheonj/lookie-backend'
    REGISTRY_IMAGE_NGINX   = 'sheonj/lookie-nginx'
    REGISTRY_IMAGE_AI      = 'sheonj/lookie-ai'

    // ============================================================
    // [BUILD PATH] repo 구조에 맞는 build context / Dockerfile 경로
    // ============================================================
    BACKEND_CONTEXT    = 'app/backend'
    BACKEND_DOCKERFILE = 'app/backend/Dockerfile'
    NGINX_CONTEXT      = '.'
    NGINX_DOCKERFILE   = 'infra/nginx/Dockerfile'
    AI_CONTEXT         = 'app/ai-server'
    AI_DOCKERFILE      = 'app/ai-server/Dockerfile'

    // ============================================================
    // [NOTIFY] Mattermost 알림
    // ============================================================
    MM_WEBHOOK_CRED_ID = 'mattermost-webhook'
    PUBLIC_JENKINS_URL = 'http://i14b105.p.ssafy.io:9000'

    // ============================================================
    // [LOG] stage별 로그 파일명(워크스페이스에 생성)
    // ============================================================
    BACKEND_LOG  = 'ci_backend.log'
    FRONTEND_LOG = 'ci_frontend.log'
    DEPLOY_LOG   = 'ci_deploy.log'

    // ============================================================
    // [CI - Redis/MySQL] MR 테스트용 (호스트 포트 충돌 방지 위해 랜덤 포트 사용)
    // ============================================================
    CI_REDIS_CONTAINER = 'ci-redis'
    CI_REDIS_IMAGE     = 'redis:7-alpine'

    CI_MYSQL_CONTAINER = 'ci-mysql'
    CI_MYSQL_IMAGE     = 'mysql:8.0'
    CI_MYSQL_DB        = 'lookie'
    CI_MYSQL_USER      = 'lookie'
    CI_MYSQL_PASSWORD  = 'lookiepass'
    CI_MYSQL_ROOTPW    = 'rootpass'

    // ============================================================
    // [DOCKER] 빌드 성능 옵션
    // ============================================================
    DOCKER_BUILDKIT = '1'
    COMPOSE_DOCKER_CLI_BUILD = '1'
  }

  stages {

    // ============================================================
    // 1) Detect Context
    // ============================================================
    stage('Detect Context') {
      steps {
        script {
          // 여러 webhook 변수가 들어와도 동작하도록 "첫 번째로 값 있는 키"를 선택
          def pick = { List<String> keys ->
            for (k in keys) {
              def v = env."${k}"
              if (v != null && v.toString().trim()) return v.toString().trim()
            }
            return ''
          }

          // 이벤트 종류 감지(GitLab/Generic webhook 변수 차이 흡수)
          env.EVENT_KIND = pick(['OBJECT_KIND','object_kind','objectKind','X_GITLAB_EVENT','gitlabEventType','event_type'])
          env.EVENT_KIND = (env.EVENT_KIND ?: '').trim()
          if (env.EVENT_KIND.toLowerCase().contains('merge')) env.EVENT_KIND = 'merge_request'
          if (env.EVENT_KIND.toLowerCase().contains('push'))  env.EVENT_KIND = 'push'

          // push 이벤트일 때 브랜치명 추출(refs/heads/xxx → xxx)
          def refRaw = pick(['REF','ref','GIT_REF','gitRef','refChanges_0_refId'])
          env.PUSH_BRANCH = (refRaw ?: '').replace('refs/heads/', '').trim()

          // MR 이벤트일 때 source/target 브랜치 추출
          env.MR_SOURCE = pick(['MR_SOURCE','mr_source','SOURCE_BRANCH','source_branch','sourceBranch','gitlabSourceBranch']).trim()
          env.MR_TARGET = pick(['MR_TARGET','mr_target','TARGET_BRANCH','target_branch','targetBranch','gitlabTargetBranch']).trim()

          // 실행자 정보(가능한 필드들을 모두 커버)
          env.ACTOR = pick([
            'MR_USER_NAME','MR_USER_USERNAME',
            'PUSH_USER_NAME','PUSH_USER_USERNAME',
            'user_name','user_username',
            'GITLAB_USER_NAME','GITLAB_USER_USERNAME',
            'gitlabUserName','gitlabUserUsername'
          ]).trim()
          if (!env.ACTOR) env.ACTOR = 'unknown'

          // 실행 플래그 초기화
          // - MR: 테스트/빌드만 수행 (이미지 push/배포 금지)
          // - develop push: 이미지 build+push 후 배포
          env.RUN_BACKEND  = "false"
          env.RUN_FRONTEND = "false"
          env.RUN_BUILDIMG = "false"
          env.RUN_DEPLOY   = "false"

          // MR이면 백/프 테스트·빌드 수행
          if (env.EVENT_KIND == 'merge_request') {
            env.RUN_BACKEND  = "true"
            env.RUN_FRONTEND = "true"
          }

          // develop push면 이미지 build/push + 배포
          if (env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop') {
            env.RUN_BUILDIMG = "true"
            env.RUN_DEPLOY   = "true"
          }

          // Checkout 대상 브랜치 결정
          env.CHECKOUT_BRANCH = ''
          if (env.EVENT_KIND == 'merge_request' && env.MR_SOURCE) {
            env.CHECKOUT_BRANCH = env.MR_SOURCE
          } else if (env.EVENT_KIND == 'push' && env.PUSH_BRANCH) {
            env.CHECKOUT_BRANCH = env.PUSH_BRANCH
          }

          echo """
[kind=${env.EVENT_KIND}]
actor=${env.ACTOR}
pushBranch=${env.PUSH_BRANCH}
mrSource=${env.MR_SOURCE}
mrTarget=${env.MR_TARGET}
checkoutBranch=${env.CHECKOUT_BRANCH}
plan: BE=${env.RUN_BACKEND}, FE=${env.RUN_FRONTEND}, BUILDIMG=${env.RUN_BUILDIMG}, DEPLOY=${env.RUN_DEPLOY}
""".trim()
        }
      }
    }

    // ============================================================
    // 2) Checkout
    // ============================================================
    stage('Checkout') {
      when {
        expression {
          env.RUN_BACKEND == "true" ||
          env.RUN_FRONTEND == "true" ||
          env.RUN_BUILDIMG == "true" ||
          env.RUN_DEPLOY == "true"
        }
      }
      steps {
        checkout scm

        // ⚠️ quoting 안전하게: sh(멀티라인) 안에서 bash -lc "..." 로 통일
        sh '''
          bash -lc "
            set -euo pipefail

            if [ -n \\"${CHECKOUT_BRANCH:-}\\" ]; then
              git rev-parse --verify \\"refs/remotes/origin/${CHECKOUT_BRANCH}\\" >/dev/null 2>&1 || {
                echo \\"[ERROR] origin/${CHECKOUT_BRANCH} not found\\"
                git branch -r || true
                exit 1
              }
              git checkout -B \\"${CHECKOUT_BRANCH}\\" \\"refs/remotes/origin/${CHECKOUT_BRANCH}\\"
            fi

            git branch --show-current
            git log -1 --oneline
          "
        '''
      }
    }

    // ============================================================
    // 3) MR: Backend Test
    // ============================================================
    stage('Backend Test (MR only)') {
      when { expression { env.EVENT_KIND == 'merge_request' && env.RUN_BACKEND == "true" } }
      steps {
        dir('app/backend') {
          sh '''
            bash -lc "
              set -euo pipefail
              : > ../../${BACKEND_LOG}

              docker version >/dev/null 2>&1 || {
                echo \\"[ERROR] docker not available\\" | tee -a ../../${BACKEND_LOG}
                exit 1
              }

              docker rm -f \\"${CI_REDIS_CONTAINER}\\" >/dev/null 2>&1 || true
              docker rm -f \\"${CI_MYSQL_CONTAINER}\\" >/dev/null 2>&1 || true

              docker pull \\"${CI_MYSQL_IMAGE}\\" >/dev/null 2>&1 || true
              docker run -d --name \\"${CI_MYSQL_CONTAINER}\\" \
                -e MYSQL_ROOT_PASSWORD=\\"${CI_MYSQL_ROOTPW}\\" \
                -e MYSQL_DATABASE=\\"${CI_MYSQL_DB}\\" \
                -e MYSQL_USER=\\"${CI_MYSQL_USER}\\" \
                -e MYSQL_PASSWORD=\\"${CI_MYSQL_PASSWORD}\\" \
                -p 0:3306 \
                \\"${CI_MYSQL_IMAGE}\\" >/dev/null

              MYSQL_HOST_PORT=\\"$(docker port \\"${CI_MYSQL_CONTAINER}\\" 3306/tcp | sed -E 's/.*:([0-9]+)$/\\\\1/' | tail -n 1)\\"
              [ -n \\"${MYSQL_HOST_PORT}\\" ] || { echo \\"[ERROR] mysql port detect failed\\" | tee -a ../../${BACKEND_LOG}; exit 1; }

              for i in $(seq 1 90); do
                if docker exec \\"${CI_MYSQL_CONTAINER}\\" mysqladmin ping -uroot -p\\"${CI_MYSQL_ROOTPW}\\" --silent >/dev/null 2>&1; then
                  if docker exec \\"${CI_MYSQL_CONTAINER}\\" mysql -uroot -p\\"${CI_MYSQL_ROOTPW}\\" -e \\"SELECT 1\\" >/dev/null 2>&1; then
                    break
                  fi
                fi
                sleep 1
                [ \\"$i\\" -eq 90 ] && { echo \\"[ERROR] mysql readiness timeout\\" | tee -a ../../${BACKEND_LOG}; exit 1; }
              done

              docker pull \\"${CI_REDIS_IMAGE}\\" >/dev/null 2>&1 || true
              docker run -d --name \\"${CI_REDIS_CONTAINER}\\" -p 0:6379 \\"${CI_REDIS_IMAGE}\\" >/dev/null

              REDIS_HOST_PORT=\\"$(docker port \\"${CI_REDIS_CONTAINER}\\" 6379/tcp | sed -E 's/.*:([0-9]+)$/\\\\1/' | tail -n 1)\\"
              [ -n \\"${REDIS_HOST_PORT}\\" ] || { echo \\"[ERROR] redis port detect failed\\" | tee -a ../../${BACKEND_LOG}; exit 1; }

              for i in $(seq 1 30); do
                if docker exec \\"${CI_REDIS_CONTAINER}\\" redis-cli ping 2>/dev/null | grep -q PONG; then
                  break
                fi
                sleep 1
                [ \\"$i\\" -eq 30 ] && { echo \\"[ERROR] redis readiness timeout\\" | tee -a ../../${BACKEND_LOG}; exit 1; }
              done

              chmod +x mvnw || true
              ./mvnw -q clean test \
                -Dspring.profiles.active=ci \
                -Dspring.datasource.url=\\"jdbc:mysql://127.0.0.1:${MYSQL_HOST_PORT}/${CI_MYSQL_DB}?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC\\" \
                -Dspring.datasource.username=\\"${CI_MYSQL_USER}\\" \
                -Dspring.datasource.password=\\"${CI_MYSQL_PASSWORD}\\" \
                -Dspring.data.redis.host=127.0.0.1 \
                -Dspring.data.redis.port=\\"${REDIS_HOST_PORT}\\" \
                -Dspring.redis.host=127.0.0.1 \
                -Dspring.redis.port=\\"${REDIS_HOST_PORT}\\" \
                2>&1 | tee -a ../../${BACKEND_LOG}
            "
          '''
        }
      }
      post {
        always {
          // 성공/실패 무관하게 정리
          sh '''
            bash -lc "
              docker rm -f \\"${CI_REDIS_CONTAINER}\\" >/dev/null 2>&1 || true
              docker rm -f \\"${CI_MYSQL_CONTAINER}\\" >/dev/null 2>&1 || true
            "
          '''
        }
      }
    }

    // ============================================================
    // MR: AI Server Test (Only Build & Test, No Push)
    // ============================================================
    stage('AI Test (MR only)') {
      when { expression { env.EVENT_KIND == 'merge_request' } }
      steps {
        script {
          def testTag = "test"

          // ✅ Groovy """ 안에서는 bash -lc "..." 로 통일 (따옴표 충돌 제거)
          sh """
            bash -lc "
              set -euo pipefail
              echo '[INFO] AI Server MR Test Start...'

              docker build -f '${AI_DOCKERFILE}' -t '${REGISTRY_IMAGE_AI}:${testTag}' '${AI_CONTEXT}'
              docker run --rm '${REGISTRY_IMAGE_AI}:${testTag}' pytest /app/test_main.py

              echo '[INFO] MR Test Passed! (Ready to Merge)'
            "
          """
        }
      }
    }

    // ============================================================
    // 4) MR: Frontend Build
    // ============================================================
    stage('Frontend Build (MR only)') {
      when { expression { env.EVENT_KIND == 'merge_request' && env.RUN_FRONTEND == "true" } }
      steps {
        dir('app/frontend') {
          sh '''
            bash -lc "
              set -euo pipefail
              : > ../../${FRONTEND_LOG}

              docker version >/dev/null 2>&1 || {
                echo \\"[ERROR] docker not available\\" | tee -a ../../${FRONTEND_LOG}
                exit 1
              }

              docker pull node:20-alpine >/dev/null 2>&1 || true
              mkdir -p \\"${HOME}/.npm\\"

              docker run --rm \
                -v \\"$PWD\\":/app -w /app \
                -v \\"${HOME}/.npm\\":/root/.npm \
                node:20-alpine sh -lc \\"set -euo pipefail; npm ci; npm run build\\" \
                2>&1 | tee -a ../../${FRONTEND_LOG}
            "
          '''
        }
      }
    }

    // ============================================================
    // 5-1) develop push: Build & Push Backend & Nginx
    // ============================================================
    stage('Build & Push: Backend & Nginx') {
      when { expression { env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop' && env.RUN_BUILDIMG == "true" } }
      steps {
        script {
          env.IMAGE_TAG = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
          echo "IMAGE_TAG=${env.IMAGE_TAG}"
        }

        withCredentials([usernamePassword(
          credentialsId: env.DOCKERHUB_CRED_ID,
          usernameVariable: 'DH_USER',
          passwordVariable: 'DH_PASS'
        )]) {
          sh '''
            bash -lc "
              set -euo pipefail

              echo \\"$DH_PASS\\" | docker login -u \\"$DH_USER\\" --password-stdin

              echo '[INFO] Backend Build...'
              docker build -f \\"${BACKEND_DOCKERFILE}\\" -t \\"${REGISTRY_IMAGE_BACKEND}:${IMAGE_TAG}\\" \\"${BACKEND_CONTEXT}\\"
              docker push \\"${REGISTRY_IMAGE_BACKEND}:${IMAGE_TAG}\\"

              echo '[INFO] Nginx Build...'
              docker build -f \\"${NGINX_DOCKERFILE}\\" -t \\"${REGISTRY_IMAGE_NGINX}:${IMAGE_TAG}\\" \\"${NGINX_CONTEXT}\\"
              docker push \\"${REGISTRY_IMAGE_NGINX}:${IMAGE_TAG}\\"
            "
          '''
        }
      }
    }

    // ============================================================
    // 5-2) develop push: Build & Push AI Server (변경 감지 시)
    // ============================================================
    stage('Build & Push: AI Server') {
      when {
        allOf {
          expression { env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop' && env.RUN_BUILDIMG == "true" }
          anyOf {
            changeset "app/ai-server/**"
            changeset "Jenkinsfile"
          }
        }
      }
      steps {
        script {
          if (!env.IMAGE_TAG) {
            env.IMAGE_TAG = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
          }
        }

        withCredentials([usernamePassword(
          credentialsId: env.DOCKERHUB_CRED_ID,
          usernameVariable: 'DH_USER',
          passwordVariable: 'DH_PASS'
        )]) {
          sh '''
            bash -lc "
              set -euo pipefail

              echo \\"$DH_PASS\\" | docker login -u \\"$DH_USER\\" --password-stdin

              echo '[INFO] AI Server Changed. Starting Build...'
              docker build -f \\"${AI_DOCKERFILE}\\" -t \\"${REGISTRY_IMAGE_AI}:${IMAGE_TAG}\\" \\"${AI_CONTEXT}\\"

              echo '[INFO] AI Server Test Running...'
              docker run --rm \\"${REGISTRY_IMAGE_AI}:${IMAGE_TAG}\\" pytest /app/test_main.py

              echo '[INFO] Test Passed! Pushing image...'
              docker push \\"${REGISTRY_IMAGE_AI}:${IMAGE_TAG}\\"
            "
          '''
        }
      }
    }

    // ============================================================
    // 6) develop push: Deploy (pull based)
    // ✅ 여기서 기존 에러 발생 → 따옴표 충돌을 제거한 버전
    // ============================================================
    stage('Deploy (develop push only, pull based)') {
      when { expression { env.EVENT_KIND == 'push' && env.PUSH_BRANCH == 'develop' && env.RUN_DEPLOY == "true" } }
      steps {
        script {
          if (!env.IMAGE_TAG?.trim()) {
            env.IMAGE_TAG = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
          }
          echo "Deploy IMAGE_TAG=${env.IMAGE_TAG}"
        }

        withCredentials([usernamePassword(
          credentialsId: env.DOCKERHUB_CRED_ID,
          usernameVariable: 'DH_USER',
          passwordVariable: 'DH_PASS'
        )]) {
          sshagent(credentials: [env.SSH_CRED_ID]) {
            sh '''
              bash -lc "
                set -euo pipefail
                : > \\"${DEPLOY_LOG}\\"

                mkdir -p ~/.ssh
                ssh-keyscan -H \\"${DEPLOY_HOST}\\" >> ~/.ssh/known_hosts 2>/dev/null || true

                ssh \\"${DEPLOY_USER}@${DEPLOY_HOST}\\" \\
                  \\"set -euo pipefail

                  mkdir -p ${DEPLOY_DIR}
                  cd ${DEPLOY_DIR}

                  if [ ! -d .git ]; then
                    git clone ${GIT_REPO_SSH} .
                  fi

                  git fetch origin
                  git checkout -B develop origin/develop

                  export REGISTRY_IMAGE_BACKEND=${REGISTRY_IMAGE_BACKEND}
                  export REGISTRY_IMAGE_NGINX=${REGISTRY_IMAGE_NGINX}
                  export REGISTRY_IMAGE_AI=${REGISTRY_IMAGE_AI}
                  export IMAGE_TAG=${IMAGE_TAG}

                  echo ${DH_PASS} | docker login -u ${DH_USER} --password-stdin >/dev/null

                  echo '[INFO] Deploy core services (without AI)'
                  docker compose -f ${COMPOSE_PROD_FILE} pull
                  docker compose -f ${COMPOSE_PROD_FILE} up -d

                  if docker manifest inspect ${REGISTRY_IMAGE_AI}:${IMAGE_TAG} >/dev/null 2>&1; then
                    echo '[INFO] AI image found -> deploying ai-server'
                    docker compose -f ${COMPOSE_PROD_FILE} --profile ai pull
                    docker compose -f ${COMPOSE_PROD_FILE} --profile ai up -d
                  else
                    echo '[INFO] AI image not found -> skipping ai-server'
                  fi

                  docker image prune -f >/dev/null 2>&1 || true
                  \\" 2>&1 | tee -a \\"${DEPLOY_LOG}\\"
              "
            '''
          }
        }
      }
    }
  }

  // ============================================================
  // post: 항상 Mattermost 알림 전송
  // ============================================================
  post {
    always {
      script {
        def ok = (currentBuild.currentResult == 'SUCCESS')
        def kind = env.EVENT_KIND ?: ''
        def branch = (kind == 'merge_request') ? (env.MR_SOURCE ?: '') : (env.PUSH_BRANCH ?: env.BRANCH_NAME ?: '')
        def title = ok ? ":white_check_mark: Jenkins 성공" : ":x: Jenkins 실패"

        // 폴더형 job에서도 정상 링크가 되도록 URL 구성
        def jobName = (env.JOB_NAME ?: '').trim()
        def buildNo = (env.BUILD_NUMBER ?: '').trim()
        def jobPath = jobName ? jobName.split('/').collect { "job/${it}" }.join('/') : ''
        def buildUrl = jobPath ? "${env.PUBLIC_JENKINS_URL}/${jobPath}/${buildNo}/" : env.PUBLIC_JENKINS_URL

        mmNotify(ok, [
          title   : title,
          mention : '@channel',
          kind    : kind,
          actor   : env.ACTOR ?: 'unknown',
          branch  : branch,
          target  : (env.MR_TARGET ?: ''),
          buildUrl: buildUrl,
          credId  : env.MM_WEBHOOK_CRED_ID
        ])
      }
    }
  }
}

// ============================================================
// Mattermost 알림 함수
// ============================================================
def mmNotify(boolean success, Map info) {
  def icon  = success ? ":jenkins:" : ":warning:"
  def title = info.title ?: (success ? ":white_check_mark: Jenkins 성공" : ":x: Jenkins 실패")

  def lines = []
  if (info.mention)  lines << "${info.mention}"
  if (info.kind)     lines << "**이벤트:** `${info.kind}`"
  if (info.actor)    lines << "**실행자:** `${info.actor}`"
  if (info.branch)   lines << "**브랜치:** `${info.branch}`"
  if (info.target)   lines << "**타겟:** `${info.target}`"
  if (info.buildUrl) lines << "**Jenkins:** ${info.buildUrl}"

  def payload = groovy.json.JsonOutput.toJson([
    username  : "Jenkins",
    icon_emoji: icon,
    text      : title + "\n" + lines.join("\n")
  ])

  writeFile file: 'mm_payload.json', text: payload

  withCredentials([string(credentialsId: info.credId, variable: 'MM_WEBHOOK')]) {
    sh '''
      curl -sS -X POST -H 'Content-Type: application/json' \
        --data-binary @mm_payload.json \
        "$MM_WEBHOOK" >/dev/null
    '''
  }
}
