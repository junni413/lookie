pipeline {
  agent none

  environment {
    DEPLOY_HOST = 'i14b105.p.ssafy.io'
    DEPLOY_USER = 'ubuntu'
    DEPLOY_DIR  = '/home/ubuntu/lookie/S14P11B105'

    // 정책: MR은 develop 대상이면 CI, develop push면 CI+배포
    CI_TARGET_BRANCH = 'develop'
    DEPLOY_BRANCH    = 'develop'

    // 실행환경 고정
    NODE_VERSION = '24'
    MAVEN_IMAGE  = 'maven:3.9.9-eclipse-temurin-17'
    NODE_IMAGE   = "node:${NODE_VERSION}-alpine"

    // Jenkins Credentials
    SSH_CRED_ID    = 'ec2-ssh-key'
    GITLAB_CRED_ID = 'gitlab-deploy-token'

    // repo (토큰은 Jenkins credentials로 처리)
    GIT_REPO_HTTP  = 'lab.ssafy.com/s14-webmobile1-sub1/S14P11B105.git'
  }

  options {
    timestamps()
    disableConcurrentBuilds()
    timeout(time: 30, unit: 'MINUTES')
    // ✅ 정석: default checkout 막고, 우리가 GitSCM으로 1번만 checkout 하게 함
    skipDefaultCheckout(true)
  }

  stages {

    // ==================================================
    // 1) Context: MR인지 push인지 / 배포 여부 결정
    // ==================================================
    stage('Detect Context') {
      agent any
      steps {
        script {
          def norm = { s ->
            (s ?: "")
              .replaceFirst(/^origin\//, "")
              .replaceFirst(/^\*\//, "")
              .trim()
          }

          def mrIid = (env.gitlabMergeRequestIid ?: env.gitlabMergeRequestId ?: "").trim()
          def isMR  = (mrIid != "")

          def src    = norm(env.gitlabSourceBranch)
          def tgt    = norm(env.gitlabTargetBranch)
          def pushBr = norm(env.gitlabBranch ?: env.GIT_BRANCH)

          echo "[Context] isMR=${isMR}"
          echo "[Context] pushBranch=${pushBr}"
          echo "[Context] sourceBranch=${src}"
          echo "[Context] targetBranch=${tgt}"

          boolean shouldBuild  = false
          boolean shouldDeploy = false
          String checkoutBranch = ""

          if (isMR) {
            // MR: target이 develop일 때만 CI
            shouldBuild  = (tgt == env.CI_TARGET_BRANCH)
            shouldDeploy = false
            checkoutBranch = src
          } else {
            // push: develop일 때만 CI+배포
            shouldBuild  = (pushBr == env.DEPLOY_BRANCH)
            shouldDeploy = (pushBr == env.DEPLOY_BRANCH)
            checkoutBranch = pushBr
          }

          env.SHOULD_BUILD    = shouldBuild.toString()
          env.SHOULD_DEPLOY   = shouldDeploy.toString()
          env.CHECKOUT_BRANCH = checkoutBranch

          if (env.SHOULD_BUILD == 'true' && (!env.CHECKOUT_BRANCH?.trim())) {
            error("[Guard] CHECKOUT_BRANCH is empty. Check GitLab webhook/plugin variables (gitlabSourceBranch/gitlabBranch).")
          }

          echo "[Guard] SHOULD_BUILD=${env.SHOULD_BUILD}, SHOULD_DEPLOY=${env.SHOULD_DEPLOY}, CHECKOUT_BRANCH=${env.CHECKOUT_BRANCH}"
        }
      }
    }

    // ==================================================
    // 2) Checkout (정석: GitSCM 1회 + credentials 강제)
    // ==================================================
    stage('Checkout') {
      agent any
      when { expression { env.SHOULD_BUILD == 'true' } }
      steps {
        checkout([
          $class: 'GitSCM',
          branches: [[name: "*/${env.CHECKOUT_BRANCH}"]],
          userRemoteConfigs: [[
            url: "https://${env.GIT_REPO_HTTP}",
            credentialsId: "${env.GITLAB_CRED_ID}"
          ]],
          extensions: [
            [$class: 'WipeWorkspace'],   // 깨끗한 워크스페이스(원하면 제거 가능)
            [$class: 'CloneOption', noTags: false, shallow: false, timeout: 20]
          ]
        ])

        sh '''#!/usr/bin/env bash
          set -euo pipefail
          echo "[Checkout] branch=$(git rev-parse --abbrev-ref HEAD)"
          echo "[Checkout] commit=$(git rev-parse HEAD)"
        '''
      }
    }

    // ==================================================
    // 3) Backend 최소 테스트 (MR/Develop 공통)
    // ==================================================
    stage('Backend - Minimal Tests') {
      when { expression { env.SHOULD_BUILD == 'true' } }
      agent {
        docker {
          image "${MAVEN_IMAGE}"
          reuseNode true
          args "-v $HOME/.m2:/root/.m2"
        }
      }
      steps {
        sh '''#!/usr/bin/env bash
          set -euo pipefail
          echo "=== [Backend] start ==="

          if [ -f "app/backend/mvnw" ]; then
            cd app/backend
            sed -i 's/\\r$//' mvnw || true
            chmod +x mvnw

            echo "[Backend] ./mvnw -B test"
            ./mvnw -B test

            if [ "${SHOULD_DEPLOY}" = "true" ]; then
              echo "[Backend] ./mvnw -B -DskipTests package"
              ./mvnw -B -DskipTests package
            else
              echo "[Backend] MR mode -> skip package"
            fi
          else
            echo "[Backend] skip (no app/backend/mvnw)"
          fi

          echo "=== [Backend] done ==="
        '''
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: 'app/backend/**/target/surefire-reports/*.xml'
          archiveArtifacts allowEmptyArchive: true, artifacts: 'app/backend/**/target/*.jar'
        }
      }
    }

    // ==================================================
    // 4) Frontend 최소 체크 (MR/Develop 공통)
    // ==================================================
    stage('Frontend - Minimal Checks') {
      when { expression { env.SHOULD_BUILD == 'true' } }
      agent {
        docker {
          image "${NODE_IMAGE}"
          reuseNode true
          args "-v $HOME/.npm:/root/.npm"
        }
      }
      steps {
        sh '''#!/usr/bin/env bash
          set -euo pipefail
          echo "=== [Frontend] start ==="

          if [ -f "app/frontend/package.json" ]; then
            cd app/frontend
            echo "[Frontend] node=$(node -v), npm=$(npm -v)"

            if [ -f package-lock.json ]; then
              npm ci
            else
              npm install
            fi

            has_script () {
              node -e "const p=require('./package.json'); process.exit((p.scripts && p.scripts['$1'])?0:1)"
            }

            if has_script lint; then npm run lint; else echo "[Frontend] skip lint"; fi
            if has_script test; then npm test; else echo "[Frontend] skip test"; fi

            if [ "${SHOULD_DEPLOY}" = "true" ]; then
              if has_script build; then npm run build; else echo "[Frontend] skip build"; fi
            else
              echo "[Frontend] MR mode -> skip build"
            fi
          else
            echo "[Frontend] skip (no app/frontend/package.json)"
          fi

          echo "=== [Frontend] done ==="
        '''
      }
      post {
        always {
          junit allowEmptyResults: true, testResults: 'app/frontend/**/junit*.xml'
          archiveArtifacts allowEmptyArchive: true, artifacts: 'app/frontend/dist/**'
        }
      }
    }

    // ==================================================
    // 5) Deploy (develop push/merge만)
    // ==================================================
    stage('Deploy to EC2') {
      agent any
      when { expression { env.SHOULD_DEPLOY == 'true' } }
      steps {
        sshagent(credentials: ["${SSH_CRED_ID}"]) {
          withCredentials([usernamePassword(
            credentialsId: "${GITLAB_CRED_ID}",
            usernameVariable: 'GL_USER',
            passwordVariable: 'GL_TOKEN'
          )]) {
            sh '''#!/usr/bin/env bash
              set -euo pipefail

              REMOTE="${DEPLOY_USER}@${DEPLOY_HOST}"
              REPO_URL="https://${GL_USER}:${GL_TOKEN}@${GIT_REPO_HTTP}"
              DEPLOY_BR="${DEPLOY_BRANCH}"

              ssh -o StrictHostKeyChecking=no "$REMOTE" /bin/bash -s <<EOF
set -euo pipefail

echo "=== [Deploy] start ==="
mkdir -p "${DEPLOY_DIR}"
cd "${DEPLOY_DIR}"

if [ ! -d ".git" ]; then
  git clone "${REPO_URL}" .
else
  git remote set-url origin "${REPO_URL}"
fi

git fetch --all --prune
git checkout "${DEPLOY_BR}" || git checkout -b "${DEPLOY_BR}" "origin/${DEPLOY_BR}"
git reset --hard "origin/${DEPLOY_BR}"

echo "[Env] checking .env"
if [ ! -f .env ]; then
  echo "ERROR: .env is missing. Stop deploy."
  echo "       Create ${DEPLOY_DIR}/.env on the server (do NOT commit .env)."
  exit 1
fi

docker compose -f docker-compose.yml up -d --build
docker ps
echo "=== [Deploy] done ==="
EOF
            '''
          }
        }
      }
    }
  }

  post {
    success { echo '✅ SUCCESS' }
    failure { echo '❌ FAILURE - check console log' }
    aborted { echo '⏭️ SKIPPED/ABORTED' }
  }
}
