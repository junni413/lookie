# =========================
# Frontend build stage (Vite - dev build)
# =========================
FROM node:24-alpine AS build
WORKDIR /app

# ✅ 의존성 먼저 (캐시 효율)
COPY app/frontend/package*.json ./
RUN npm ci

# ✅ 소스 복사
COPY app/frontend/ .

# ✅ dev용 빌드
# - Vite에서 mode를 나눠 쓰고 있다면 development로 빌드
# - (프로젝트에 mode가 없으면 그냥 npm run build만 해도 됨)
RUN npm run build -- --mode development

# =========================
# Nginx serve stage (dev)
# =========================
FROM nginx:alpine

# 기본 설정 제거
RUN rm -f /etc/nginx/conf.d/default.conf

# ✅ dev용 conf 복사
COPY infra/nginx/dev/conf.d/ /etc/nginx/conf.d/

# ✅ 빌드 결과물(dist) 복사
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
